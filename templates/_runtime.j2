  // ---- RUNTIME HELPERS (shared across all game templates) ----

  // ctx.roundRect polyfill for older browsers
  if (!ctx.roundRect) {
    ctx.roundRect = function(x, y, w, h, r) {
      this.beginPath();
      this.moveTo(x + r, y);
      this.lineTo(x + w - r, y);
      this.quadraticCurveTo(x + w, y, x + w, y + r);
      this.lineTo(x + w, y + h - r);
      this.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
      this.lineTo(x + r, y + h);
      this.quadraticCurveTo(x, y + h, x, y + h - r);
      this.lineTo(x, y + r);
      this.quadraticCurveTo(x, y, x + r, y);
      this.closePath();
    };
  }

  // Shared key state and keyup listener
  var keys = {};
  document.addEventListener('keyup', function(e) { keys[e.key] = false; });

  // Shared overlay function — uses _RT_W / _RT_H set by each template
  function drawOverlay(title, subtitle, titleColor) {
    var t = Date.now() / 1000;
    var ac = titleColor || '{{ OVERLAY_COLOR | default("#60a5fa") }}';

    // Dim the entire canvas
    ctx.fillStyle = 'rgba(0,0,0,0.80)';
    ctx.fillRect(0, 0, _RT_W, _RT_H);

    // Card panel
    var cw = Math.min(_RT_W - 48, 380);
    var ch = 148;
    var cx2 = (_RT_W - cw) / 2;
    var cy2 = (_RT_H - ch) / 2;

    ctx.fillStyle = 'rgba(8,8,20,0.97)';
    ctx.roundRect(cx2, cy2, cw, ch, 10);
    ctx.fill();

    // Card border in accent color
    ctx.save();
    ctx.globalAlpha = 0.50;
    ctx.strokeStyle = ac;
    ctx.lineWidth = 1.5;
    ctx.roundRect(cx2, cy2, cw, ch, 10);
    ctx.stroke();
    ctx.restore();

    // Thin separator line
    ctx.save();
    ctx.globalAlpha = 0.20;
    ctx.strokeStyle = ac;
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(cx2 + 24, cy2 + 76);
    ctx.lineTo(cx2 + cw - 24, cy2 + 76);
    ctx.stroke();
    ctx.restore();

    // Title
    ctx.textAlign = 'center';
    ctx.font = 'bold 28px Courier New';
    ctx.fillStyle = ac;
    ctx.fillText(title, _RT_W / 2, cy2 + 52);

    // Subtitle — gently pulsing
    ctx.save();
    ctx.globalAlpha = 0.45 + 0.55 * Math.abs(Math.sin(t * 2.6));
    ctx.font = '13px Courier New';
    ctx.fillStyle = '#d1d5db';
    ctx.fillText(subtitle, _RT_W / 2, cy2 + 110);
    ctx.restore();

    ctx.textAlign = 'left';
  }
