{% set OVERLAY_COLOR = '#60a5fa' %}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ game.name }}</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    background: #0d0d1a;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    font-family: 'Courier New', monospace;
    color: #60a5fa;
  }
  h1 { margin-bottom: 10px; font-size: 24px; color: #60a5fa; letter-spacing: 3px; }
  canvas { border: 2px solid #334155; display: block; }
  #info { margin-top: 8px; font-size: 13px; color: #334155; }
</style>
</head>
<body>
<h1>{{ game.name }}</h1>
<canvas id="gameCanvas" width="{{ game.canvas.width }}" height="{{ game.canvas.height }}"></canvas>
<div id="info">Arrow Keys / WASD to move &nbsp;|&nbsp; Z: Undo &nbsp;|&nbsp; R: Reset &nbsp;|&nbsp; Enter: Restart</div>
<script>
(function() {
  'use strict';

  var CELL = {{ game.map.cell_size }};
  var CANVAS_W = {{ game.canvas.width }};
  var CANVAS_H = {{ game.canvas.height }};
  var BG_COLOR = "{{ game.background }}";
  var PLAYER_COLOR = "{{ game.player.color }}";

  var TILE_MAP = {};
  {% if game.tiles %}{% for tile in game.tiles.tiles %}
  TILE_MAP["{{ tile.symbol }}"] = {
    solid: {{ 'true' if tile.solid else 'false' }},
    color: "{{ tile.color or '#000' }}",
    name: "{{ tile.name }}",
    pushable: {{ 'true' if (tile.tag and tile.tag == 'pushable') else 'false' }},
    isTarget: {{ 'true' if (tile.tag and tile.tag == 'target') else 'false' }}
  };
  {% endfor %}{% endif %}

  var RAW_LAYOUT = [{% for row in game.map.layout %}{{ row | tojson }}{% if not loop.last %},{% endif %}{% endfor %}];
  var PLAYER_SPAWN = { col: {{ player_spawn.col }}, row: {{ player_spawn.row }} };

  // 3 built-in fallback puzzle layouts (used for level cycling)
  var BUILTIN_LEVELS = [
    // Level 1: simple
    {
      layout: [
        "########",
        "#......#",
        "#.#B.T.#",
        "#......#",
        "#.T.B..#",
        "#...@..#",
        "########"
      ],
      spawn: { col: 4, row: 5 }
    },
    // Level 2: medium
    {
      layout: [
        "##########",
        "#........#",
        "#.##.##..#",
        "#.#B...T.#",
        "#....#...#",
        "#.T..B...#",
        "#....#...#",
        "#...@....#",
        "##########"
      ],
      spawn: { col: 4, row: 7 }
    },
    // Level 3: harder
    {
      layout: [
        "###########",
        "#.........#",
        "#.##.###..#",
        "#.#B..B.T.#",
        "#.#.......#",
        "#.T..#.T..#",
        "#....B....#",
        "#....@....#",
        "###########"
      ],
      spawn: { col: 5, row: 7 }
    }
  ];

  var currentLevelIdx = 0;  // 0 = model layout, 1-3 = built-in levels

  var canvas = document.getElementById('gameCanvas');
  var ctx = canvas.getContext('2d');

  var ROWS = RAW_LAYOUT.length;
  var COLS = RAW_LAYOUT[0].length;

  var STATE_PLAYING = 'PLAYING';
  var STATE_WIN     = 'WIN';

  var grid = [];
  var totalTargets = 0;
  var player = {};
  var moveCount = 0;
  var history = [];
  var gameState = STATE_PLAYING;
  var gameTime = 0;
  var winFlashTimer = 0;
  var winAutoAdvanceTimer = 0;

{% include '_behavior_dsl.j2' %}
  var _RT_W = CANVAS_W;
  var _RT_H = CANVAS_H;
{% include '_runtime.j2' %}
  function _ruleHook_loseLife()           { /* no lives in Sokoban */ }
  function _ruleHook_addPoints(pts)       { /* no score in Sokoban */ }
  function _ruleHook_destroyEnemy()       { /* no enemies */ }
  function _ruleHook_destroyAllEnemies()  { /* no enemies */ }
  function _ruleHook_nextLevel()          { nextLevel(); }
  function _ruleHook_spawn(e, l)          { /* no spawn */ }

  function buildGridFromLayout(layout) {
    grid = [];
    totalTargets = 0;
    var rows = layout.length;
    var cols = layout[0].length;
    for (var r = 0; r < rows; r++) {
      grid[r] = [];
      for (var c = 0; c < cols; c++) {
        var ch = (layout[r][c] !== undefined) ? layout[r][c] : '.';
        var tile = TILE_MAP[ch] || { solid: false, color: BG_COLOR, name: 'floor', pushable: false, isTarget: false };
        // Handle '@' as player spawn (floor)
        if (ch === '@') {
          tile = TILE_MAP['.'] || { solid: false, color: BG_COLOR, name: 'floor', pushable: false, isTarget: false };
          ch = '.';
        }
        grid[r][c] = {
          symbol: ch,
          originalSymbol: ch,
          solid: tile.solid,
          color: tile.color,
          name: tile.name,
          pushable: tile.pushable,
          isTarget: tile.isTarget
        };
        if (tile.isTarget || ch === 'T' || ch === 'X') totalTargets++;
      }
    }
  }

  function buildGrid() {
    if (currentLevelIdx === 0) {
      buildGridFromLayout(RAW_LAYOUT);
    } else {
      var lvl = BUILTIN_LEVELS[(currentLevelIdx - 1) % BUILTIN_LEVELS.length];
      buildGridFromLayout(lvl.layout);
    }
  }

  function getCurrentSpawn() {
    if (currentLevelIdx === 0) return PLAYER_SPAWN;
    var lvl = BUILTIN_LEVELS[(currentLevelIdx - 1) % BUILTIN_LEVELS.length];
    return lvl.spawn;
  }

  function initPlayer() {
    var spawn = getCurrentSpawn();
    player = {
      col: spawn.col,
      row: spawn.row,
      facingDx: 0,
      facingDy: -1
    };
    // Clear player spawn cell
    if (grid[player.row] && grid[player.row][player.col]) {
      grid[player.row][player.col].solid = false;
      grid[player.row][player.col].pushable = false;
    }
  }

  function countBoxesOnTargets() {
    var count = 0;
    for (var r = 0; r < ROWS; r++) {
      for (var c = 0; c < COLS; c++) {
        var cell = grid[r][c];
        // A box on target: symbol is 'X' or (pushable and isTarget)
        if (cell.symbol === 'X' || (cell.pushable && cell.isTarget)) count++;
      }
    }
    return count;
  }

  function snapshotGrid() {
    var snap = [];
    for (var r = 0; r < ROWS; r++) {
      snap[r] = [];
      for (var c = 0; c < COLS; c++) {
        snap[r][c] = {
          symbol: grid[r][c].symbol,
          solid: grid[r][c].solid,
          color: grid[r][c].color,
          name: grid[r][c].name,
          pushable: grid[r][c].pushable,
          isTarget: grid[r][c].isTarget,
          originalSymbol: grid[r][c].originalSymbol
        };
      }
    }
    return snap;
  }

  function restoreGrid(snap) {
    for (var r = 0; r < ROWS; r++) {
      for (var c = 0; c < COLS; c++) {
        grid[r][c].symbol = snap[r][c].symbol;
        grid[r][c].solid = snap[r][c].solid;
        grid[r][c].color = snap[r][c].color;
        grid[r][c].name = snap[r][c].name;
        grid[r][c].pushable = snap[r][c].pushable;
        grid[r][c].isTarget = snap[r][c].isTarget;
        grid[r][c].originalSymbol = snap[r][c].originalSymbol;
      }
    }
  }

  function tryMove(dc, dr) {
    if (gameState !== STATE_PLAYING) return;

    player.facingDx = dc;
    player.facingDy = dr;

    var nc = player.col + dc;
    var nr = player.row + dr;

    if (nc < 0 || nc >= COLS || nr < 0 || nr >= ROWS) return;

    var targetCell = grid[nr][nc];

    if (targetCell.solid && !targetCell.pushable) return; // wall

    if (targetCell.pushable) {
      // Try to push box
      var bc = nc + dc;
      var br = nr + dr;
      if (bc < 0 || bc >= COLS || br < 0 || br >= ROWS) return;
      var behindCell = grid[br][bc];
      if (behindCell.solid || behindCell.pushable) return; // can't push

      // Save history
      if (history.length >= 50) history.shift();
      history.push({ playerCol: player.col, playerRow: player.row, grid: snapshotGrid() });

      // Move box
      var wasTarget = behindCell.isTarget || behindCell.originalSymbol === 'T';
      var boxWasOnTarget = targetCell.isTarget || targetCell.originalSymbol === 'T' || targetCell.symbol === 'X';

      // Update behind cell (box lands here)
      behindCell.pushable = true;
      behindCell.solid = true;
      if (wasTarget) {
        behindCell.symbol = 'X';
        behindCell.color = TILE_MAP['X'] ? TILE_MAP['X'].color : '#15803d';
        behindCell.name = 'box_on_target';
        behindCell.isTarget = true;
      } else {
        behindCell.symbol = 'B';
        behindCell.color = TILE_MAP['B'] ? TILE_MAP['B'].color : '#92400e';
        behindCell.name = 'box';
        behindCell.isTarget = false;
      }

      // Update target cell (box leaves here)
      targetCell.pushable = false;
      targetCell.solid = false;
      if (boxWasOnTarget) {
        targetCell.symbol = 'T';
        targetCell.color = TILE_MAP['T'] ? TILE_MAP['T'].color : '#0f172a';
        targetCell.name = 'target';
        targetCell.isTarget = true;
      } else {
        targetCell.symbol = '.';
        targetCell.color = TILE_MAP['.'] ? TILE_MAP['.'].color : '#0f172a';
        targetCell.name = 'floor';
        targetCell.isTarget = false;
      }

      player.col = nc;
      player.row = nr;
      moveCount++;

      // Check win — immediate solution check
      if (countBoxesOnTargets() >= totalTargets && totalTargets > 0) {
        gameState = STATE_WIN;
        winFlashTimer = 1.5;
        winAutoAdvanceTimer = 3.0;
      }
    } else {
      // Just move player
      if (history.length >= 50) history.shift();
      history.push({ playerCol: player.col, playerRow: player.row, grid: snapshotGrid() });

      player.col = nc;
      player.row = nr;
      moveCount++;
    }
  }

  function undo() {
    if (history.length === 0) return;
    var state = history.pop();
    player.col = state.playerCol;
    player.row = state.playerRow;
    restoreGrid(state.grid);
    moveCount = Math.max(0, moveCount - 1);
    gameState = STATE_PLAYING;
  }

  var keyHandled = {};
  document.addEventListener('keydown', function(e) {
    if (!keys[e.key]) {
      keys[e.key] = true;
      keyHandled[e.key] = false;
    }
    if ((gameState === STATE_WIN) && (e.key === 'Enter' || e.key === ' ')) {
      e.preventDefault();
      // Auto-advance to next level
      currentLevelIdx = (currentLevelIdx + 1) % (BUILTIN_LEVELS.length + 1);
      restartGame();
      return;
    }
    if (e.key === 'z' || e.key === 'Z') {
      e.preventDefault();
      undo();
      return;
    }
    if (e.key === 'r' || e.key === 'R') {
      e.preventDefault();
      restartGame();
      return;
    }
    // Level select: N = next level, P = previous level
    if (e.key === 'n' || e.key === 'N') {
      e.preventDefault();
      currentLevelIdx = (currentLevelIdx + 1) % (BUILTIN_LEVELS.length + 1);
      restartGame();
      return;
    }
    if (e.key === 'p' || e.key === 'P') {
      e.preventDefault();
      currentLevelIdx = (currentLevelIdx - 1 + BUILTIN_LEVELS.length + 1) % (BUILTIN_LEVELS.length + 1);
      restartGame();
      return;
    }
    if (['ArrowLeft','ArrowRight','ArrowUp','ArrowDown','a','d','w','s'].indexOf(e.key) >= 0) {
      e.preventDefault();
    }
  });
  document.addEventListener('keyup', function(e) {
    keyHandled[e.key] = false;
  });

  function processInput() {
    var dirMap = [
      { key: 'ArrowUp',    dc: 0, dr: -1 },
      { key: 'ArrowDown',  dc: 0, dr: 1 },
      { key: 'ArrowLeft',  dc: -1, dr: 0 },
      { key: 'ArrowRight', dc: 1, dr: 0 },
      { key: 'w', dc: 0, dr: -1 },
      { key: 's', dc: 0, dr: 1 },
      { key: 'a', dc: -1, dr: 0 },
      { key: 'd', dc: 1, dr: 0 }
    ];
    for (var i = 0; i < dirMap.length; i++) {
      var d = dirMap[i];
      if (keys[d.key] && !keyHandled[d.key]) {
        keyHandled[d.key] = true;
        tryMove(d.dc, d.dr);
        return;
      }
    }
  }

  // Drawing
  function drawGrid() {
    for (var r = 0; r < ROWS; r++) {
      for (var c = 0; c < COLS; c++) {
        var cell = grid[r][c];
        var px = c * CELL;
        var py = r * CELL;

        if (cell.name === 'wall') {
          // Dark blue-grey wall
          ctx.fillStyle = cell.color;
          ctx.fillRect(px, py, CELL, CELL);
          ctx.strokeStyle = 'rgba(255,255,255,0.08)';
          ctx.lineWidth = 1;
          ctx.strokeRect(px + 0.5, py + 0.5, CELL - 1, CELL - 1);
        } else if (cell.name === 'floor') {
          ctx.fillStyle = cell.color;
          ctx.fillRect(px, py, CELL, CELL);
        } else if (cell.name === 'target') {
          // Floor with yellow X marker
          ctx.fillStyle = TILE_MAP['.'] ? TILE_MAP['.'].color : '#0f172a';
          ctx.fillRect(px, py, CELL, CELL);
          ctx.strokeStyle = '#eab308';
          ctx.lineWidth = 2;
          ctx.beginPath();
          ctx.moveTo(px + 6, py + 6);
          ctx.lineTo(px + CELL - 6, py + CELL - 6);
          ctx.moveTo(px + CELL - 6, py + 6);
          ctx.lineTo(px + 6, py + CELL - 6);
          ctx.stroke();
          // Circle
          ctx.strokeStyle = '#eab308';
          ctx.lineWidth = 1.5;
          ctx.beginPath();
          ctx.arc(px + CELL / 2, py + CELL / 2, CELL * 0.3, 0, Math.PI * 2);
          ctx.stroke();
        } else if (cell.name === 'box') {
          // Brown box
          ctx.fillStyle = cell.color;
          ctx.fillRect(px + 2, py + 2, CELL - 4, CELL - 4);
          ctx.strokeStyle = 'rgba(0,0,0,0.5)';
          ctx.lineWidth = 2;
          ctx.strokeRect(px + 2, py + 2, CELL - 4, CELL - 4);
          // Plus highlight
          ctx.strokeStyle = 'rgba(255,200,100,0.4)';
          ctx.lineWidth = 2;
          ctx.beginPath();
          ctx.moveTo(px + CELL / 2, py + 6);
          ctx.lineTo(px + CELL / 2, py + CELL - 6);
          ctx.moveTo(px + 6, py + CELL / 2);
          ctx.lineTo(px + CELL - 6, py + CELL / 2);
          ctx.stroke();
        } else if (cell.name === 'box_on_target') {
          // Green box on target
          ctx.fillStyle = cell.color;
          ctx.fillRect(px + 2, py + 2, CELL - 4, CELL - 4);
          ctx.strokeStyle = 'rgba(0,0,0,0.4)';
          ctx.lineWidth = 2;
          ctx.strokeRect(px + 2, py + 2, CELL - 4, CELL - 4);
          // X marker (success)
          ctx.strokeStyle = 'rgba(255,255,255,0.6)';
          ctx.lineWidth = 2;
          ctx.beginPath();
          ctx.moveTo(px + 7, py + 7);
          ctx.lineTo(px + CELL - 7, py + CELL - 7);
          ctx.moveTo(px + CELL - 7, py + 7);
          ctx.lineTo(px + 7, py + CELL - 7);
          ctx.stroke();
        } else {
          ctx.fillStyle = BG_COLOR;
          ctx.fillRect(px, py, CELL, CELL);
        }
      }
    }
  }

  function drawPlayer() {
    var px = player.col * CELL + CELL / 2;
    var py = player.row * CELL + CELL / 2;
    var r = CELL * 0.36;

    ctx.save();
    ctx.shadowColor = PLAYER_COLOR;
    ctx.shadowBlur = 12;
    ctx.fillStyle = PLAYER_COLOR;
    ctx.beginPath();
    ctx.arc(px, py, r, 0, Math.PI * 2);
    ctx.fill();

    // Arrow indicator for facing direction
    var adx = player.facingDx;
    var ady = player.facingDy;
    if (adx !== 0 || ady !== 0) {
      ctx.fillStyle = 'rgba(255,255,255,0.7)';
      ctx.beginPath();
      var ax = px + adx * r * 0.55;
      var ay = py + ady * r * 0.55;
      var perpX = -ady * r * 0.2;
      var perpY = adx * r * 0.2;
      ctx.moveTo(ax + adx * r * 0.3, ay + ady * r * 0.3);
      ctx.lineTo(ax - adx * r * 0.1 + perpX, ay - ady * r * 0.1 + perpY);
      ctx.lineTo(ax - adx * r * 0.1 - perpX, ay - ady * r * 0.1 - perpY);
      ctx.closePath();
      ctx.fill();
    }

    ctx.restore();
  }

  function drawUI() {
    ctx.font = 'bold 14px Courier New';
    ctx.fillStyle = '#60a5fa';
    var movesText = 'MOVES: ' + moveCount;
    var boxesText = 'BOXES: ' + countBoxesOnTargets() + '/' + totalTargets;
    ctx.fillText(movesText, CANVAS_W - 8 - ctx.measureText(movesText).width, 20);
    ctx.fillText(boxesText, 8, 20);

    ctx.font = '11px Courier New';
    ctx.fillStyle = '#334155';
    var levelName = currentLevelIdx === 0 ? 'Model' : 'Level ' + currentLevelIdx;
    var hint = 'Z:Undo  R:Reset  N/P:Level (' + levelName + ')';
    ctx.fillText(hint, (CANVAS_W - ctx.measureText(hint).width) / 2, 20);
  }

  function draw() {
    ctx.fillStyle = BG_COLOR;
    ctx.fillRect(0, 0, CANVAS_W, CANVAS_H);

    drawGrid();
    drawPlayer();
    drawUI();

    if (gameState === STATE_WIN) {
      // Congratulation color flash
      if (winFlashTimer > 0) {
        var flashAlpha = 0.3 + 0.2 * Math.sin(gameTime * 10);
        ctx.fillStyle = 'rgba(34,197,94,' + flashAlpha + ')';
        ctx.fillRect(0, 0, CANVAS_W, CANVAS_H);
      }
      drawOverlay('PUZZLE SOLVED!', 'All boxes on targets!', '#22c55e');
    }
  }

  var lastTime = null;

  function gameLoop(timestamp) {
    if (lastTime === null) lastTime = timestamp;
    var dt = Math.min((timestamp - lastTime) / 1000, 0.05);
    lastTime = timestamp;
    gameTime += dt;

    if (gameState === STATE_PLAYING) {
      processInput();
      updateRuleTimers(dt);
    } else if (gameState === STATE_WIN) {
      if (winFlashTimer > 0) winFlashTimer -= dt;
      if (winAutoAdvanceTimer > 0) {
        winAutoAdvanceTimer -= dt;
        if (winAutoAdvanceTimer <= 0) {
          // Auto-advance to next level
          currentLevelIdx = (currentLevelIdx + 1) % (BUILTIN_LEVELS.length + 1);
          restartGame();
        }
      }
    }

    draw();
    requestAnimationFrame(gameLoop);
  }

  function restartGame() {
    moveCount = 0;
    history = [];
    gameState = STATE_PLAYING;
    gameTime = 0;
    winFlashTimer = 0;
    winAutoAdvanceTimer = 0;
    buildGrid();
    initPlayer();
  }

  buildGrid();
  initPlayer();
  requestAnimationFrame(gameLoop);

})();
</script>
</body>
</html>
