{% set OVERLAY_COLOR = '#00cc00' %}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ game.name }}</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    background: #111;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    font-family: 'Courier New', monospace;
    color: #fff;
  }
  h1 { margin-bottom: 10px; font-size: 24px; color: #00cc00; letter-spacing: 3px; }
  canvas { border: 2px solid #333; display: block; }
  #info { margin-top: 8px; font-size: 13px; color: #888; }
</style>
</head>
<body>
<h1>{{ game.name }}</h1>
<canvas id="gameCanvas" width="{{ game.canvas.width }}" height="{{ game.canvas.height }}"></canvas>
<div id="info">Arrow Keys / WASD to move</div>
<script>
(function() {
  'use strict';

  var CANVAS_W  = {{ game.canvas.width }};
  var CANVAS_H  = {{ game.canvas.height }};
  var BG_COLOR  = "{{ game.background }}";
  var CELL      = {{ game.map.cell_size }};

  var RAW_LAYOUT = [
    {% for row in game.map.layout %}
    {{ row | tojson }}{% if not loop.last %},{% endif %}

    {% endfor %}
  ];

  var ROWS = RAW_LAYOUT.length;
  var COLS = RAW_LAYOUT[0].length;

  var SNAKE_COLOR      = "{{ game.player.color }}";
  var HEAD_COLOR       = "{{ game.player.head_color if game.player.head_color else game.player.color }}";
  var SNAKE_SPEED      = {{ game.player.speed }};
  {% if player_spawn %}
  var START_X          = {{ player_spawn.col }};
  var START_Y          = {{ player_spawn.row }};
  {% else %}
  var START_X          = {{ game.player.start_x }};
  var START_Y          = {{ game.player.start_y }};
  {% endif %}
  var START_LENGTH     = {{ game.player.start_length if game.player.start_length else 3 }};
  var START_DIR        = "{{ game.player.start_direction if game.player.start_direction else 'right' }}";
  var GROW_ON_EAT      = {{ 'true' if game.player.grow_on_eat else 'false' }};

  var FOOD_COLOR       = "{{ game.food.color if game.food else '#ff4444' }}";
  var FOOD_SCORE       = {{ game.food.score if game.food else 10 }};
  var FOOD_RESPAWN     = {{ 'true' if game.food and game.food.respawn else 'true' }};
  var FOOD_COUNT       = {{ game.food.count if game.food else 1 }};

  var UI_SCORE_POS     = "{{ game.ui.score_pos if game.ui and game.ui.score_pos else 'top_left' }}";

  // Wall collision: if model has 'wall' in collision, die on wall; otherwise wrap
  var COLLISION_WALL   = {{ 'true' if game.mechanics and game.mechanics.collision and 'wall' in game.mechanics.collision.targets else 'false' }};
  var COLLISION_SELF   = true;

  var HIGH_SCORE_KEY = 'snake_high_score_{{ game.name | replace(" ", "_") }}';
  var highScore = parseInt(localStorage.getItem(HIGH_SCORE_KEY) || '0', 10);

  /* ---- SOUNDS (Web Audio API — generated from DSL model) ---- */
{% if sounds %}
{% for snd in sounds %}
  function playSound_{{ snd.name }}() {
    try {
      var ctx_ = new (window.AudioContext || window.webkitAudioContext)();
{% if snd.sound_type == 'beep' %}
      var osc = ctx_.createOscillator();
      var gain = ctx_.createGain();
      osc.connect(gain); gain.connect(ctx_.destination);
      osc.type = 'square';
      osc.frequency.value = {{ snd.frequency if snd.frequency else 440 }};
      gain.gain.setValueAtTime({{ snd.volume if snd.volume else 0.3 }}, ctx_.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.001, ctx_.currentTime + {{ snd.duration if snd.duration else 0.08 }});
      osc.start(); osc.stop(ctx_.currentTime + {{ snd.duration if snd.duration else 0.08 }});
{% elif snd.sound_type == 'sweep_up' %}
      var osc = ctx_.createOscillator();
      var gain = ctx_.createGain();
      osc.connect(gain); gain.connect(ctx_.destination);
      osc.type = 'sine';
      osc.frequency.setValueAtTime({{ snd.frequency if snd.frequency else 200 }}, ctx_.currentTime);
      osc.frequency.exponentialRampToValueAtTime({{ (snd.frequency * 4) if snd.frequency else 800 }}, ctx_.currentTime + {{ snd.duration if snd.duration else 0.2 }});
      gain.gain.setValueAtTime({{ snd.volume if snd.volume else 0.3 }}, ctx_.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.001, ctx_.currentTime + {{ snd.duration if snd.duration else 0.2 }});
      osc.start(); osc.stop(ctx_.currentTime + {{ snd.duration if snd.duration else 0.2 }});
{% elif snd.sound_type == 'sweep_down' %}
      var osc = ctx_.createOscillator();
      var gain = ctx_.createGain();
      osc.connect(gain); gain.connect(ctx_.destination);
      osc.type = 'sine';
      osc.frequency.setValueAtTime({{ (snd.frequency * 4) if snd.frequency else 800 }}, ctx_.currentTime);
      osc.frequency.exponentialRampToValueAtTime({{ snd.frequency if snd.frequency else 200 }}, ctx_.currentTime + {{ snd.duration if snd.duration else 0.2 }});
      gain.gain.setValueAtTime({{ snd.volume if snd.volume else 0.3 }}, ctx_.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.001, ctx_.currentTime + {{ snd.duration if snd.duration else 0.2 }});
      osc.start(); osc.stop(ctx_.currentTime + {{ snd.duration if snd.duration else 0.2 }});
{% elif snd.sound_type == 'explosion' or snd.sound_type == 'noise' %}
      var bufSize = ctx_.sampleRate * {{ snd.duration if snd.duration else 0.3 }};
      var buf = ctx_.createBuffer(1, bufSize, ctx_.sampleRate);
      var data = buf.getChannelData(0);
      for (var _i = 0; _i < bufSize; _i++) data[_i] = Math.random() * 2 - 1;
      var src = ctx_.createBufferSource();
      src.buffer = buf;
      var gain = ctx_.createGain();
      src.connect(gain); gain.connect(ctx_.destination);
      gain.gain.setValueAtTime({{ snd.volume if snd.volume else 0.4 }}, ctx_.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.001, ctx_.currentTime + {{ snd.duration if snd.duration else 0.3 }});
      src.start(); src.stop(ctx_.currentTime + {{ snd.duration if snd.duration else 0.3 }});
{% endif %}
    } catch(e) {}
  }
{% endfor %}
{% else %}
  function playSound_eat() {}
  function playSound_die() {}
  function playSound_level_up() {}
{% endif %}

  /* ---- ITEMS (drops — from DSL model) ---- */
  var ITEM_DEFS = [
{% for it in items %}
    { name: "{{ it.name }}", symbol: {{ it.symbol | tojson }}, color: "{{ it.color }}", score: {{ it.score if it.score else 0 }}, effect: "{{ it.effect if it.effect else '' }}", duration: {{ it.duration if it.duration else 0 }}, dropChance: {{ it.drop_chance if it.drop_chance else 0 }} }{% if not loop.last %},{% endif %}

{% endfor %}
  ];
  var activeItems = [];
  var speedBoostTimer = 0;
  var scoreMultTimer = 0;
  var scoreMult = 1;

{% include '_behavior_dsl.j2' %}
  function _ruleHook_loseLife() { gameState = STATE_GAMEOVER; }
  function _ruleHook_addPoints(pts) { score += pts; }
  function _ruleHook_destroyEnemy() { /* no enemies in snake */ }
  function _ruleHook_destroyAllEnemies() { /* no enemies in snake */ }
  function _ruleHook_nextLevel() { currentSpeed = SNAKE_SPEED + 2; TICK_INTERVAL = 1.0 / currentSpeed; }
  function _ruleHook_spawn(entity, location) { spawnFood(); }

  var STATE_PLAYING  = 'PLAYING';
  var STATE_PAUSED   = 'PAUSED';
  var STATE_GAMEOVER = 'GAME_OVER';

  var snake = [];
  var direction = { dx: 1, dy: 0 };
  var nextDir   = { dx: 1, dy: 0 };
  var foods     = [];
  var score     = 0;
  var foodEaten = 0;
  var gameState = STATE_PLAYING;
  var tickAccum = 0;
  var currentSpeed = SNAKE_SPEED;
  var TICK_INTERVAL = 1.0 / SNAKE_SPEED;

  var wallGrid = [];

  function buildWallGrid() {
    wallGrid = [];
    for (var r = 0; r < ROWS; r++) {
      wallGrid[r] = [];
      for (var c = 0; c < COLS; c++) {
        var ch = (RAW_LAYOUT[r] && RAW_LAYOUT[r][c]) ? RAW_LAYOUT[r][c] : ' ';
        wallGrid[r][c] = (ch === '#');
      }
    }
  }

  function isWall(col, row) {
    if (row < 0 || row >= ROWS || col < 0 || col >= COLS) return true;
    return wallGrid[row] && wallGrid[row][col];
  }

  function dirFromStr(s) {
    if (s === 'up')    return { dx: 0, dy: -1 };
    if (s === 'down')  return { dx: 0, dy:  1 };
    if (s === 'left')  return { dx: -1, dy: 0 };
    if (s === 'right') return { dx:  1, dy: 0 };
    return { dx: 1, dy: 0 };
  }

  function initSnake() {
    snake = [];
    var d = dirFromStr(START_DIR);
    direction = { dx: d.dx, dy: d.dy };
    nextDir   = { dx: d.dx, dy: d.dy };
    for (var i = 0; i < START_LENGTH; i++) {
      snake.push({ x: START_X - d.dx * i, y: START_Y - d.dy * i });
    }
  }

  function spawnFood() {
    var attempts = 0;
    while (foods.length < FOOD_COUNT && attempts < 1000) {
      attempts++;
      var fx = Math.floor(Math.random() * COLS);
      var fy = Math.floor(Math.random() * ROWS);
      if (isWall(fx, fy)) continue;
      var onSnake = false;
      for (var i = 0; i < snake.length; i++) {
        if (snake[i].x === fx && snake[i].y === fy) { onSnake = true; break; }
      }
      var onFood = false;
      for (var j = 0; j < foods.length; j++) {
        if (foods[j].x === fx && foods[j].y === fy) { onFood = true; break; }
      }
      if (!onSnake && !onFood) {
        foods.push({ x: fx, y: fy });
      }
    }
  }

  function tick() {
    direction = { dx: nextDir.dx, dy: nextDir.dy };

    var head = snake[0];
    var newHead = { x: head.x + direction.dx, y: head.y + direction.dy };

    // Wall collision or wrap
    if (COLLISION_WALL) {
      if (isWall(newHead.x, newHead.y)) {
{% if sounds | selectattr('name', 'equalto', 'die') | list %}
        playSound_die();
{% endif %}
        gameState = STATE_GAMEOVER;
        return;
      }
    } else {
      // Wrap around edges (only if not a wall tile)
      if (newHead.x < 0) newHead.x = COLS - 1;
      else if (newHead.x >= COLS) newHead.x = 0;
      if (newHead.y < 0) newHead.y = ROWS - 1;
      else if (newHead.y >= ROWS) newHead.y = 0;
      // Still die on wall tiles
      if (isWall(newHead.x, newHead.y)) {
{% if sounds | selectattr('name', 'equalto', 'die') | list %}
        playSound_die();
{% endif %}
        gameState = STATE_GAMEOVER;
        return;
      }
    }

    if (COLLISION_SELF) {
      for (var i = 0; i < snake.length - 1; i++) {
        if (snake[i].x === newHead.x && snake[i].y === newHead.y) {
{% if sounds | selectattr('name', 'equalto', 'die') | list %}
          playSound_die();
{% endif %}
          gameState = STATE_GAMEOVER;
          return;
        }
      }
    }

    snake.unshift(newHead);

    var ateFood = false;
    for (var f = 0; f < foods.length; f++) {
      if (foods[f].x === newHead.x && foods[f].y === newHead.y) {
        score += FOOD_SCORE * scoreMult;
        foods.splice(f, 1);
        ateFood = true;
        foodEaten++;
{% if sounds | selectattr('name', 'equalto', 'eat') | list %}
        playSound_eat();
{% endif %}
        // Speed up every 5 foods eaten
        if (foodEaten % 5 === 0) {
          currentSpeed = SNAKE_SPEED + Math.floor(foodEaten / 5) * 2;
          TICK_INTERVAL = 1.0 / currentSpeed;
{% if sounds | selectattr('name', 'equalto', 'level_up') | list %}
          playSound_level_up();
{% endif %}
        }
        if (FOOD_RESPAWN) spawnFood();
        // Maybe spawn an item
        trySpawnItem();
        break;
      }
    }

    // Check item collection
    for (var ii = activeItems.length - 1; ii >= 0; ii--) {
      var it = activeItems[ii];
      if (it.x === newHead.x && it.y === newHead.y) {
        collectItem(it);
        activeItems.splice(ii, 1);
      }
    }

    if (!ateFood || !GROW_ON_EAT) {
      snake.pop();
    }
  }

  function trySpawnItem() {
    if (ITEM_DEFS.length === 0) return;
    for (var d = 0; d < ITEM_DEFS.length; d++) {
      var def = ITEM_DEFS[d];
      if (Math.random() < def.dropChance) {
        var attempts = 0;
        while (attempts < 200) {
          attempts++;
          var ix = Math.floor(Math.random() * COLS);
          var iy = Math.floor(Math.random() * ROWS);
          if (isWall(ix, iy)) continue;
          var onSnake = false;
          for (var s = 0; s < snake.length; s++) {
            if (snake[s].x === ix && snake[s].y === iy) { onSnake = true; break; }
          }
          if (!onSnake) {
            activeItems.push({ x: ix, y: iy, def: def, life: 10 });
            break;
          }
        }
        break;
      }
    }
  }

  function collectItem(it) {
    if (it.def.score > 0) score += it.def.score * scoreMult;
    if (it.def.effect === 'speed_up') {
      speedBoostTimer = it.def.duration || 5;
      currentSpeed = SNAKE_SPEED * 1.5;
      TICK_INTERVAL = 1.0 / currentSpeed;
    }
    if (it.def.effect === 'slow_down') {
      speedBoostTimer = -(it.def.duration || 5);
      currentSpeed = Math.max(1, SNAKE_SPEED * 0.6);
      TICK_INTERVAL = 1.0 / currentSpeed;
    }
    if (it.def.effect === 'score_multiply') {
      scoreMultTimer = it.def.duration || 5;
      scoreMult = 2;
    }
  }

  function updateItemTimers(dt) {
    // Expire item tiles
    for (var i = activeItems.length - 1; i >= 0; i--) {
      activeItems[i].life -= dt;
      if (activeItems[i].life <= 0) activeItems.splice(i, 1);
    }
    // Speed boost expiry
    if (speedBoostTimer > 0) {
      speedBoostTimer -= dt;
      if (speedBoostTimer <= 0) {
        speedBoostTimer = 0;
        currentSpeed = SNAKE_SPEED + Math.floor(foodEaten / 5) * 2;
        TICK_INTERVAL = 1.0 / currentSpeed;
      }
    }
    // Score multiplier expiry
    if (scoreMultTimer > 0) {
      scoreMultTimer -= dt;
      if (scoreMultTimer <= 0) { scoreMultTimer = 0; scoreMult = 1; }
    }
  }

  function uiPos(posStr, textWidth, lineHeight, index) {
    var margin = 8;
    var x, y;
    if (posStr === 'top_left')       { x = margin; y = margin + lineHeight * (index + 1); }
    else if (posStr === 'top_right') { x = CANVAS_W - margin - textWidth; y = margin + lineHeight * (index + 1); }
    else if (posStr === 'top_center'){ x = (CANVAS_W - textWidth) / 2; y = margin + lineHeight * (index + 1); }
    else if (posStr === 'bottom_left'){ x = margin; y = CANVAS_H - margin - lineHeight * index; }
    else if (posStr === 'bottom_right'){ x = CANVAS_W - margin - textWidth; y = CANVAS_H - margin - lineHeight * index; }
    else if (posStr === 'bottom_center'){ x = (CANVAS_W - textWidth) / 2; y = CANVAS_H - margin - lineHeight * index; }
    else { x = margin; y = margin + lineHeight; }
    return { x: x, y: y };
  }

  function drawWalls() {
    for (var r = 0; r < ROWS; r++) {
      for (var c = 0; c < COLS; c++) {
        if (wallGrid[r][c]) {
          ctx.fillStyle = '#334455';
          ctx.fillRect(c * CELL, r * CELL, CELL, CELL);
          ctx.strokeStyle = '#223344';
          ctx.lineWidth = 1;
          ctx.strokeRect(c * CELL, r * CELL, CELL, CELL);
        }
      }
    }
  }

  function drawSnake() {
    for (var i = snake.length - 1; i >= 0; i--) {
      var seg = snake[i];
      var px = seg.x * CELL;
      var py = seg.y * CELL;
      var padding = 1;

      ctx.fillStyle = (i === 0) ? HEAD_COLOR : SNAKE_COLOR;
      ctx.beginPath();
      ctx.roundRect(px + padding, py + padding, CELL - padding * 2, CELL - padding * 2, 3);
      ctx.fill();

      if (i === 0) {
        var eyeSize = CELL * 0.12;
        var eyeOffset = CELL * 0.25;
        ctx.fillStyle = '#000';

        var ex1, ey1, ex2, ey2;
        var cx2 = px + CELL / 2;
        var cy2 = py + CELL / 2;

        if (direction.dx === 1) {
          ex1 = cx2 + eyeOffset; ey1 = cy2 - eyeOffset;
          ex2 = cx2 + eyeOffset; ey2 = cy2 + eyeOffset;
        } else if (direction.dx === -1) {
          ex1 = cx2 - eyeOffset; ey1 = cy2 - eyeOffset;
          ex2 = cx2 - eyeOffset; ey2 = cy2 + eyeOffset;
        } else if (direction.dy === -1) {
          ex1 = cx2 - eyeOffset; ey1 = cy2 - eyeOffset;
          ex2 = cx2 + eyeOffset; ey2 = cy2 - eyeOffset;
        } else {
          ex1 = cx2 - eyeOffset; ey1 = cy2 + eyeOffset;
          ex2 = cx2 + eyeOffset; ey2 = cy2 + eyeOffset;
        }

        ctx.beginPath();
        ctx.arc(ex1, ey1, eyeSize, 0, Math.PI * 2);
        ctx.fill();
        ctx.beginPath();
        ctx.arc(ex2, ey2, eyeSize, 0, Math.PI * 2);
        ctx.fill();
      }
    }
  }

  function drawItems() {
    for (var i = 0; i < activeItems.length; i++) {
      var it = activeItems[i];
      var alpha = Math.min(1, it.life / 3);
      ctx.globalAlpha = alpha;
      ctx.fillStyle = it.def.color;
      ctx.font = 'bold ' + Math.round(CELL * 0.75) + 'px monospace';
      ctx.textAlign = 'center';
      ctx.fillText(it.def.symbol, it.x * CELL + CELL / 2, it.y * CELL + CELL * 0.75);
      ctx.textAlign = 'left';
      ctx.globalAlpha = 1;
    }
  }

  function drawFood() {
    for (var f = 0; f < foods.length; f++) {
      var food = foods[f];
      var fx = food.x * CELL + CELL / 2;
      var fy = food.y * CELL + CELL / 2;
      ctx.fillStyle = FOOD_COLOR;
      ctx.beginPath();
      ctx.arc(fx, fy, CELL * 0.35, 0, Math.PI * 2);
      ctx.fill();
      ctx.fillStyle = 'rgba(255,255,255,0.4)';
      ctx.beginPath();
      ctx.arc(fx - CELL * 0.1, fy - CELL * 0.1, CELL * 0.1, 0, Math.PI * 2);
      ctx.fill();
    }
  }

  function drawUI() {
    ctx.font = 'bold 14px Courier New';
    ctx.fillStyle = '#ffffff';
    var scoreText = 'SCORE: ' + score;
    var sp = uiPos(UI_SCORE_POS, ctx.measureText(scoreText).width, 18, 0);
    ctx.fillText(scoreText, sp.x, sp.y);

    // High score
    ctx.font = '11px Courier New';
    ctx.fillStyle = '#ffcc00';
    var hiText = 'BEST: ' + highScore;
    var hp = uiPos(UI_SCORE_POS, ctx.measureText(hiText).width, 18, 1);
    ctx.fillText(hiText, hp.x, hp.y);

    // Speed indicator
    ctx.font = '11px Courier New';
    ctx.fillStyle = '#888';
    var speedText = 'SPD: ' + currentSpeed;
    ctx.fillText(speedText, CANVAS_W - 8 - ctx.measureText(speedText).width, 20);
  }

  function draw() {
    ctx.fillStyle = BG_COLOR;
    ctx.fillRect(0, 0, CANVAS_W, CANVAS_H);

    drawWalls();
    drawFood();
    drawItems();
    drawSnake();
    drawUI();

    if (gameState === STATE_PAUSED) {
      drawOverlay('PAUSED', 'Press P or Escape to resume');
    } else if (gameState === STATE_GAMEOVER) {
      drawOverlay('GAME OVER', 'Score: ' + score + '  |  Press Enter to restart');
    }
  }

  document.addEventListener('keydown', function(e) {
    // Pause toggle
    if (e.key === 'p' || e.key === 'P' || e.key === 'Escape') {
      if (gameState === STATE_PLAYING) { gameState = STATE_PAUSED; e.preventDefault(); return; }
      if (gameState === STATE_PAUSED)  { gameState = STATE_PLAYING; e.preventDefault(); return; }
    }
    var dirMap = {
      'ArrowLeft':  { dx: -1, dy:  0 },
      'ArrowRight': { dx:  1, dy:  0 },
      'ArrowUp':    { dx:  0, dy: -1 },
      'ArrowDown':  { dx:  0, dy:  1 },
      'a': { dx: -1, dy:  0 },
      'd': { dx:  1, dy:  0 },
      'w': { dx:  0, dy: -1 },
      's': { dx:  0, dy:  1 }
    };
    if (dirMap[e.key]) {
      var nd = dirMap[e.key];
      if (nd.dx !== -direction.dx || nd.dy !== -direction.dy) {
        nextDir = nd;
      }
      e.preventDefault();
    }
    if ((e.key === 'Enter' || e.key === ' ') && gameState === STATE_GAMEOVER) {
      restartGame();
    }
  });

  function restartGame() {
    score = 0;
    foodEaten = 0;
    currentSpeed = SNAKE_SPEED;
    TICK_INTERVAL = 1.0 / SNAKE_SPEED;
    foods = [];
    activeItems = [];
    speedBoostTimer = 0;
    scoreMultTimer = 0;
    scoreMult = 1;
    gameState = STATE_PLAYING;
    tickAccum = 0;
    initSnake();
    spawnFood();
  }

  var canvas = document.getElementById('gameCanvas');
  var ctx    = canvas.getContext('2d');

  var _RT_W = CANVAS_W;
  var _RT_H = CANVAS_H;
{% include '_runtime.j2' %}
  var lastTime = null;

  function gameLoop(timestamp) {
    if (lastTime === null) lastTime = timestamp;
    var dt = Math.min((timestamp - lastTime) / 1000, 0.1);
    lastTime = timestamp;

    if (gameState === STATE_PLAYING) {
      updateItemTimers(dt);
      updateRuleTimers(dt);
      tickAccum += dt;
      while (tickAccum >= TICK_INTERVAL) {
        tickAccum -= TICK_INTERVAL;
        tick();
        if (gameState !== STATE_PLAYING) break;
      }
      // Update high score
      if (score > highScore) {
        highScore = score;
        localStorage.setItem(HIGH_SCORE_KEY, highScore);
      }
    }

    draw();
    requestAnimationFrame(gameLoop);
  }

  buildWallGrid();
  initSnake();
  spawnFood();
  requestAnimationFrame(gameLoop);

})();
</script>
</body>
</html>
