{% set OVERLAY_COLOR = '#60a5fa' %}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ game.name }}</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    background: #010409;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    font-family: 'Courier New', monospace;
    color: #fff;
  }
  h1 { margin-bottom: 10px; font-size: 22px; color: #60a5fa; letter-spacing: 3px; }
  canvas { border: 2px solid #1e293b; display: block; }
  #info { margin-top: 8px; font-size: 12px; color: #475569; }
</style>
</head>
<body>
<h1>{{ game.name }}</h1>
<canvas id="gameCanvas" width="{{ game.canvas.width }}" height="{{ game.canvas.height }}"></canvas>
<div id="info">← → / A D to move paddle &nbsp;|&nbsp; Any key to launch ball</div>
<script>
(function() {
  'use strict';

  var CELL      = {{ game.map.cell_size }};
  var CANVAS_W  = {{ game.canvas.width }};
  var CANVAS_H  = {{ game.canvas.height }};
  var BG_COLOR  = "{{ game.background }}";
  var PLAYER_COLOR  = "{{ game.player.color }}";
  var PLAYER_LIVES  = {{ game.player.lives if game.player.lives else 3 }};
  var PLAYER_SPEED  = {{ game.player.speed }};

  var TILE_MAP = {};
  {% if game.tiles %}
  {% for tile in game.tiles.tiles %}
  TILE_MAP["{{ tile.symbol }}"] = {
    name: "{{ tile.name }}",
    solid: {{ 'true' if tile.solid else 'false' }},
    collectible: {{ 'true' if tile.collectible else 'false' }},
    color: "{{ tile.color if tile.color else '#888888' }}",
    score: {{ tile.score if tile.score else 0 }}
  };
  {% endfor %}
  {% endif %}

  var RAW_LAYOUT = [
    {% for row in game.map.layout %}
    {{ row | tojson }}{% if not loop.last %},{% endif %}
    {% endfor %}
  ];

  var PADDLE_SPAWN_COL = {{ player_spawn.col if player_spawn else 7 }};
  var PADDLE_SPAWN_ROW = {{ player_spawn.row if player_spawn else 14 }};

  var UI_SCORE_POS = "{{ game.ui.score_pos if game.ui and game.ui.score_pos else 'top_right' }}";
  var UI_LIVES_POS = "{{ game.ui.lives_pos if game.ui and game.ui.lives_pos else 'top_left' }}";

  var HIGH_SCORE_KEY = 'breakout_high_score_{{ game.name | replace(" ", "_") }}';
  var highScore = parseInt(localStorage.getItem(HIGH_SCORE_KEY) || '0', 10);

  var canvas = document.getElementById('gameCanvas');
  var ctx    = canvas.getContext('2d');

  var ROWS = RAW_LAYOUT.length;
  var COLS = RAW_LAYOUT[0].length;

  // Game states
  var STATE_WAITING  = 'WAITING';
  var STATE_PLAYING  = 'PLAYING';
  var STATE_GAMEOVER = 'GAME_OVER';
  var STATE_WIN      = 'WIN';
  var STATE_LEVEL_UP = 'LEVEL_UP';

  // Paddle constants
  var PADDLE_W = 3 * CELL;
  var PADDLE_H = Math.round(CELL * 0.4);
  var PADDLE_Y = PADDLE_SPAWN_ROW * CELL + CELL / 2 - PADDLE_H / 2;

  // Ball constants
  var BALL_RADIUS = CELL * 0.25;
  var BASE_BALL_SPEED = 10 * CELL;  // pixels per second
  var BALL_SPEED  = BASE_BALL_SPEED;

  var grid = [];
  var totalBricks = 0;
  var bricksLeft  = 0;

  var paddle = {};
  var ball   = {};
  var balls  = [];  // multi-ball support
  var score  = 0;
  var lives  = PLAYER_LIVES;
  var level  = 1;
  var gameState = STATE_WAITING;
  var gameTime  = 0;
  var levelUpTimer = 0;

  // Power-ups
  var powerUps = [];
  var activePowerUps = {};  // type -> timer
  var POWERUP_DURATION = 10;

  // Ball trail
  var ballTrail = [];

  // Score flash particles
  var flashes = [];

  // Level color palettes for brick regeneration
  var LEVEL_PALETTES = [
    ['#ef4444','#f97316','#eab308','#22c55e','#3b82f6','#a855f7'],
    ['#06b6d4','#8b5cf6','#ec4899','#f59e0b','#10b981','#6366f1'],
    ['#ff6b6b','#ffd93d','#6bcb77','#4d96ff','#ff922b','#cc5de8'],
    ['#f72585','#7209b7','#3a0ca3','#4361ee','#4cc9f0','#4895ef']
  ];

{% include '_behavior_dsl.j2' %}
  var _RT_W = CANVAS_W;
  var _RT_H = CANVAS_H;
{% include '_runtime.j2' %}
  function _ruleHook_loseLife()           { lives = Math.max(0, lives - 1); if (lives <= 0) { gameState = STATE_GAMEOVER; } }
  function _ruleHook_addPoints(pts)       { score += pts; }
  function _ruleHook_destroyEnemy()       { /* no enemies */ }
  function _ruleHook_destroyAllEnemies()  { /* no enemies */ }
  function _ruleHook_nextLevel()          { gameState = STATE_LEVEL_UP; }
  function _ruleHook_spawn(e, l)          { /* no spawn */ }

  function buildGrid() {
    grid = [];
    totalBricks = 0;
    for (var r = 0; r < ROWS; r++) {
      grid[r] = [];
      for (var c = 0; c < COLS; c++) {
        var ch = (RAW_LAYOUT[r] && RAW_LAYOUT[r][c] !== undefined) ? RAW_LAYOUT[r][c] : '.';
        var tile = TILE_MAP[ch] || { name: 'empty', solid: false, collectible: false, color: BG_COLOR, score: 0 };
        grid[r][c] = { symbol: ch, tile: tile, eaten: false };
        if (tile.collectible && tile.solid) totalBricks++;
      }
    }
    bricksLeft = totalBricks;
  }

  function isSolid(col, row) {
    if (row < 0 || row >= ROWS || col < 0 || col >= COLS) return true;
    var cell = grid[row][col];
    return cell.tile.solid && !cell.eaten;
  }

  function initPaddle() {
    paddle = {
      x: PADDLE_SPAWN_COL * CELL - PADDLE_W / 2,
      y: PADDLE_Y,
      w: PADDLE_W,
      h: PADDLE_H,
      speed: PLAYER_SPEED * CELL
    };
    // Clamp to canvas
    paddle.x = Math.max(0, Math.min(CANVAS_W - paddle.w, paddle.x));
  }

  function initBall() {
    ball = {
      x: paddle.x + paddle.w / 2,
      y: paddle.y - BALL_RADIUS - 2,
      dx: 0,
      dy: 0,
      radius: BALL_RADIUS,
      speed: BALL_SPEED
    };
    balls = [ball];
    ballTrail = [];
  }

  function launchBall() {
    // Launch at 45° upward-left or upward-right randomly
    var angle = (Math.random() > 0.5 ? 1 : -1) * Math.PI / 4;
    ball.dx = ball.speed * Math.sin(angle);
    ball.dy = -ball.speed * Math.cos(angle);
    gameState = STATE_PLAYING;
  }

  function spawnPowerUp(brickX, brickY, brickColor) {
    if (Math.random() > 0.2) return; // 20% chance
    var types = ['wide_paddle', 'multi_ball', 'slow_ball'];
    var type = types[Math.floor(Math.random() * types.length)];
    powerUps.push({
      x: brickX + CELL / 2,
      y: brickY + CELL / 2,
      type: type,
      color: type === 'wide_paddle' ? '#60a5fa' : type === 'multi_ball' ? '#f97316' : '#a855f7',
      speed: CELL * 3,
      alive: true
    });
  }

  function applyPowerUp(type) {
    activePowerUps[type] = POWERUP_DURATION;
    if (type === 'wide_paddle') {
      paddle.w = Math.min(CELL * 6, PADDLE_W * 2);
    } else if (type === 'multi_ball') {
      // Spawn 2 extra balls from current ball positions
      for (var i = 0; i < balls.length && balls.length < 5; i++) {
        var b = balls[i];
        var nb = { x: b.x, y: b.y, dx: -b.dy, dy: b.dx, radius: b.radius, speed: b.speed };
        balls.push(nb);
      }
    } else if (type === 'slow_ball') {
      for (var j = 0; j < balls.length; j++) {
        var spd = Math.sqrt(balls[j].dx * balls[j].dx + balls[j].dy * balls[j].dy);
        if (spd > 0) {
          balls[j].dx = balls[j].dx / spd * (BALL_SPEED * 0.6);
          balls[j].dy = balls[j].dy / spd * (BALL_SPEED * 0.6);
          balls[j].speed = BALL_SPEED * 0.6;
        }
      }
    }
  }

  function updatePowerUps(dt) {
    // Move falling power-ups
    for (var i = powerUps.length - 1; i >= 0; i--) {
      var p = powerUps[i];
      if (!p.alive) { powerUps.splice(i, 1); continue; }
      p.y += p.speed * dt;
      // Off screen
      if (p.y > CANVAS_H) { powerUps.splice(i, 1); continue; }
      // Paddle catch
      if (p.y + CELL * 0.3 >= paddle.y && p.y - CELL * 0.3 <= paddle.y + paddle.h &&
          p.x >= paddle.x && p.x <= paddle.x + paddle.w) {
        applyPowerUp(p.type);
        powerUps.splice(i, 1);
      }
    }
    // Tick active power-up timers
    for (var type in activePowerUps) {
      activePowerUps[type] -= dt;
      if (activePowerUps[type] <= 0) {
        delete activePowerUps[type];
        // Restore paddle width
        if (type === 'wide_paddle') paddle.w = PADDLE_W;
        // Restore ball speed
        if (type === 'slow_ball') {
          for (var k = 0; k < balls.length; k++) {
            var spd2 = Math.sqrt(balls[k].dx * balls[k].dx + balls[k].dy * balls[k].dy);
            if (spd2 > 0) {
              balls[k].dx = balls[k].dx / spd2 * BALL_SPEED;
              balls[k].dy = balls[k].dy / spd2 * BALL_SPEED;
              balls[k].speed = BALL_SPEED;
            }
          }
        }
      }
    }
  }

  function drawPowerUps() {
    for (var i = 0; i < powerUps.length; i++) {
      var p = powerUps[i];
      ctx.save();
      ctx.shadowColor = p.color;
      ctx.shadowBlur = 10;
      ctx.fillStyle = p.color;
      ctx.fillRect(p.x - CELL * 0.4, p.y - CELL * 0.25, CELL * 0.8, CELL * 0.5);
      ctx.font = 'bold 9px Courier New';
      ctx.fillStyle = '#fff';
      ctx.textAlign = 'center';
      var label = p.type === 'wide_paddle' ? 'WIDE' : p.type === 'multi_ball' ? 'MULTI' : 'SLOW';
      ctx.fillText(label, p.x, p.y + 3);
      ctx.textAlign = 'left';
      ctx.restore();
    }
  }

  function rebuildBricksForLevel() {
    var palette = LEVEL_PALETTES[(level - 1) % LEVEL_PALETTES.length];
    var brickRow = 0;
    for (var r = 0; r < ROWS; r++) {
      for (var c = 0; c < COLS; c++) {
        var cell = grid[r][c];
        if (cell.tile.collectible && cell.tile.solid) {
          cell.eaten = false;
          // Assign new color from palette based on row
          cell.tile = {
            name: cell.tile.name,
            solid: true,
            collectible: true,
            color: palette[r % palette.length],
            score: cell.tile.score
          };
        }
      }
    }
    // Recount bricks
    bricksLeft = 0;
    for (var r2 = 0; r2 < ROWS; r2++) {
      for (var c2 = 0; c2 < COLS; c2++) {
        if (grid[r2][c2].tile.collectible && grid[r2][c2].tile.solid && !grid[r2][c2].eaten) bricksLeft++;
      }
    }
    totalBricks = bricksLeft;
  }

  document.addEventListener('keydown', function(e) {
    keys[e.key] = true;
    if ((gameState === STATE_GAMEOVER || gameState === STATE_WIN) &&
        (e.key === 'Enter' || e.key === ' ')) {
      e.preventDefault();
      restartGame();
      return;
    }
    if (gameState === STATE_WAITING) {
      launchBall();
      e.preventDefault();
      return;
    }
    if (e.key === 'ArrowLeft' || e.key === 'ArrowRight' ||
        e.key === 'a' || e.key === 'd') {
      e.preventDefault();
    }
  });

  function updatePaddle(dt) {
    var moving = false;
    if (keys['ArrowLeft'] || keys['a']) {
      paddle.x -= paddle.speed * dt;
      moving = true;
    }
    if (keys['ArrowRight'] || keys['d']) {
      paddle.x += paddle.speed * dt;
      moving = true;
    }
    // Clamp within canvas (walls are at col 0 and col COLS-1)
    var leftWall  = CELL;   // one cell wall on left
    var rightWall = (COLS - 1) * CELL - paddle.w;  // one cell wall on right
    paddle.x = Math.max(leftWall, Math.min(rightWall, paddle.x));

    // If waiting, keep ball above paddle
    if (gameState === STATE_WAITING) {
      ball.x = paddle.x + paddle.w / 2;
      ball.y = paddle.y - BALL_RADIUS - 2;
    }
  }

  function circleRectOverlap(bx, by, br, rx, ry, rw, rh) {
    var nearX = Math.max(rx, Math.min(bx, rx + rw));
    var nearY = Math.max(ry, Math.min(by, ry + rh));
    var dx = bx - nearX;
    var dy = by - nearY;
    return (dx * dx + dy * dy) < (br * br);
  }

  function updateOneBall(b, dt) {
    // Record trail
    ballTrail.push({ x: b.x, y: b.y, time: gameTime });
    if (ballTrail.length > 30) ballTrail.shift();

    b.x += b.dx * dt;
    b.y += b.dy * dt;

    // Left wall bounce
    if (b.x - b.radius < CELL) {
      b.x = CELL + b.radius;
      b.dx = Math.abs(b.dx);
    }
    // Right wall bounce
    if (b.x + b.radius > (COLS - 1) * CELL) {
      b.x = (COLS - 1) * CELL - b.radius;
      b.dx = -Math.abs(b.dx);
    }
    // Top wall bounce
    if (b.y - b.radius < CELL) {
      b.y = CELL + b.radius;
      b.dy = Math.abs(b.dy);
    }

    // Bottom — lose ball
    if (b.y - b.radius > CANVAS_H) {
      return false; // ball lost
    }

    // Paddle collision
    if (b.dy > 0 &&
        b.y + b.radius >= paddle.y &&
        b.y - b.radius <= paddle.y + paddle.h &&
        b.x >= paddle.x - b.radius &&
        b.x <= paddle.x + paddle.w + b.radius) {
      var relHit = (b.x - paddle.x) / paddle.w;
      relHit = Math.max(0.05, Math.min(0.95, relHit));
      var angle = (relHit - 0.5) * (5 * Math.PI / 6);
      b.dx = b.speed * Math.sin(angle);
      b.dy = -Math.abs(b.speed * Math.cos(angle));
      b.y = paddle.y - b.radius - 1;
    }

    // Brick collision
    for (var r = 0; r < ROWS; r++) {
      for (var c = 0; c < COLS; c++) {
        var cell = grid[r][c];
        if (cell.eaten) continue;
        if (!cell.tile.solid) continue;

        var brickX = c * CELL;
        var brickY = r * CELL;

        if (!circleRectOverlap(b.x, b.y, b.radius, brickX, brickY, CELL, CELL)) continue;

        var overlapLeft   = (b.x + b.radius) - brickX;
        var overlapRight  = (brickX + CELL) - (b.x - b.radius);
        var overlapTop    = (b.y + b.radius) - brickY;
        var overlapBottom = (brickY + CELL) - (b.y - b.radius);
        var minOverlap = Math.min(overlapLeft, overlapRight, overlapTop, overlapBottom);

        if (minOverlap === overlapLeft || minOverlap === overlapRight) {
          b.dx = -b.dx;
        } else {
          b.dy = -b.dy;
        }

        if (cell.tile.collectible) {
          cell.eaten = true;
          bricksLeft--;
          score += cell.tile.score;
          flashes.push({
            x: brickX + CELL / 2,
            y: brickY + CELL / 2,
            text: '+' + cell.tile.score,
            timer: 0.5,
            color: cell.tile.color
          });
          spawnPowerUp(brickX, brickY, cell.tile.color);
          if (bricksLeft <= 0) {
            // Level complete
            levelUpTimer = 2.0;
            gameState = STATE_LEVEL_UP;
            return true;
          }
        }
        return true; // hit one brick per frame
      }
    }
    return true;
  }

  function updateBall(dt) {
    if (gameState !== STATE_PLAYING) return;

    for (var i = balls.length - 1; i >= 0; i--) {
      var alive = updateOneBall(balls[i], dt);
      if (!alive) {
        balls.splice(i, 1);
      }
    }

    // If all balls lost
    if (balls.length === 0) {
      lives--;
      if (lives <= 0) {
        gameState = STATE_GAMEOVER;
      } else {
        initBall();
        gameState = STATE_WAITING;
      }
    }

    // Keep main ball reference in sync
    if (balls.length > 0) ball = balls[0];
  }

  function updateFlashes(dt) {
    for (var i = flashes.length - 1; i >= 0; i--) {
      flashes[i].timer -= dt;
      if (flashes[i].timer <= 0) flashes.splice(i, 1);
    }
  }

  function uiPos(posStr, textWidth, lineHeight, index) {
    var margin = 8;
    var x, y;
    if (posStr === 'top_left')        { x = margin; y = margin + lineHeight * (index + 1); }
    else if (posStr === 'top_right')  { x = CANVAS_W - margin - textWidth; y = margin + lineHeight * (index + 1); }
    else if (posStr === 'top_center') { x = (CANVAS_W - textWidth) / 2; y = margin + lineHeight * (index + 1); }
    else if (posStr === 'bottom_left'){ x = margin; y = CANVAS_H - margin - lineHeight * index; }
    else if (posStr === 'bottom_right'){ x = CANVAS_W - margin - textWidth; y = CANVAS_H - margin - lineHeight * index; }
    else if (posStr === 'bottom_center'){ x = (CANVAS_W - textWidth) / 2; y = CANVAS_H - margin - lineHeight * index; }
    else { x = margin; y = margin + lineHeight; }
    return { x: x, y: y };
  }

  function drawGrid() {
    // Background
    ctx.fillStyle = BG_COLOR;
    ctx.fillRect(0, 0, CANVAS_W, CANVAS_H);

    for (var r = 0; r < ROWS; r++) {
      for (var c = 0; c < COLS; c++) {
        var cell = grid[r][c];
        var px = c * CELL;
        var py = r * CELL;

        if (cell.tile.solid && !cell.eaten) {
          if (cell.tile.collectible) {
            // Brick with subtle border
            ctx.fillStyle = cell.tile.color;
            ctx.fillRect(px + 1, py + 1, CELL - 2, CELL - 2);
            // Darker border for depth
            ctx.strokeStyle = 'rgba(0,0,0,0.4)';
            ctx.lineWidth = 2;
            ctx.strokeRect(px + 1, py + 1, CELL - 2, CELL - 2);
            // Highlight top edge
            ctx.fillStyle = 'rgba(255,255,255,0.2)';
            ctx.fillRect(px + 2, py + 2, CELL - 4, 3);
          } else {
            // Wall
            ctx.fillStyle = cell.tile.color;
            ctx.fillRect(px, py, CELL, CELL);
            ctx.strokeStyle = 'rgba(255,255,255,0.04)';
            ctx.lineWidth = 1;
            ctx.strokeRect(px, py, CELL, CELL);
          }
        }
      }
    }
  }

  function drawPaddle() {
    var px = paddle.x;
    var py = paddle.y;
    var pw = paddle.w;
    var ph = paddle.h;

    ctx.save();
    ctx.shadowColor = PLAYER_COLOR;
    ctx.shadowBlur = 14;

    // Main paddle body
    ctx.fillStyle = PLAYER_COLOR;
    ctx.beginPath();
    ctx.roundRect(px, py, pw, ph, ph / 2);
    ctx.fill();

    // Highlight
    ctx.fillStyle = 'rgba(255,255,255,0.35)';
    ctx.beginPath();
    ctx.roundRect(px + 4, py + 2, pw - 8, ph / 2 - 2, (ph / 2 - 2) / 2);
    ctx.fill();

    ctx.restore();
  }

  function drawBall() {
    // Draw trail (last 5 positions with decreasing opacity)
    var trailLen = Math.min(5, ballTrail.length);
    for (var t = 0; t < trailLen; t++) {
      var tp = ballTrail[ballTrail.length - 1 - t];
      var alpha = (1 - t / (trailLen + 1)) * 0.4;
      ctx.globalAlpha = alpha;
      ctx.fillStyle = '#ffffff';
      ctx.beginPath();
      ctx.arc(tp.x, tp.y, ball.radius * (1 - t * 0.15), 0, Math.PI * 2);
      ctx.fill();
    }
    ctx.globalAlpha = 1;

    // Draw all balls
    for (var i = 0; i < balls.length; i++) {
      var b = balls[i];
      ctx.save();
      ctx.shadowColor = '#ffffff';
      ctx.shadowBlur = 18;
      ctx.fillStyle = '#ffffff';
      ctx.beginPath();
      ctx.arc(b.x, b.y, b.radius, 0, Math.PI * 2);
      ctx.fill();
      ctx.restore();
    }
  }

  function drawFlashes() {
    for (var i = 0; i < flashes.length; i++) {
      var f = flashes[i];
      var alpha = f.timer / 0.5;
      ctx.globalAlpha = alpha;
      ctx.font = 'bold 13px Courier New';
      ctx.fillStyle = f.color;
      ctx.textAlign = 'center';
      ctx.fillText(f.text, f.x, f.y - (1 - alpha) * 20);
      ctx.textAlign = 'left';
    }
    ctx.globalAlpha = 1;
  }

  function drawUI() {
    ctx.font = 'bold 14px Courier New';
    ctx.fillStyle = '#ffffff';

    var scoreText = 'SCORE: ' + score;
    var livesText = 'LIVES: ' + lives;
    var levelText = 'LVL: ' + level;

    var sp = uiPos(UI_SCORE_POS, ctx.measureText(scoreText).width, 18, 0);
    ctx.fillText(scoreText, sp.x, sp.y);

    ctx.font = '11px Courier New';
    ctx.fillStyle = '#ffcc00';
    var hiText = 'BEST: ' + highScore;
    var hp = uiPos(UI_SCORE_POS, ctx.measureText(hiText).width, 18, 1);
    ctx.fillText(hiText, hp.x, hp.y);

    ctx.font = 'bold 14px Courier New';
    ctx.fillStyle = '#ffffff';
    var lp = uiPos(UI_LIVES_POS, ctx.measureText(livesText).width, 18, 0);
    ctx.fillText(livesText, lp.x, lp.y);

    ctx.font = '12px Courier New';
    ctx.fillStyle = '#60a5fa';
    var lvp = uiPos('top_center', ctx.measureText(levelText).width, 18, 0);
    ctx.fillText(levelText, lvp.x, lvp.y);

    // Active power-up indicators
    var puY = 36;
    for (var type in activePowerUps) {
      var t = activePowerUps[type];
      ctx.font = '10px Courier New';
      ctx.fillStyle = type === 'wide_paddle' ? '#60a5fa' : type === 'multi_ball' ? '#f97316' : '#a855f7';
      ctx.fillText(type.replace('_', ' ').toUpperCase() + ' ' + Math.ceil(t) + 's', 8, puY);
      puY += 14;
    }
  }

  function drawWaiting() {
    ctx.fillStyle = 'rgba(0,0,0,0.45)';
    ctx.fillRect(0, CANVAS_H / 2 - 30, CANVAS_W, 60);
    ctx.textAlign = 'center';
    ctx.font = 'bold 18px Courier New';
    ctx.fillStyle = '#60a5fa';
    ctx.fillText('Press any key to launch!', CANVAS_W / 2, CANVAS_H / 2 + 6);
    ctx.textAlign = 'left';
  }

  function draw() {
    ctx.fillStyle = BG_COLOR;
    ctx.fillRect(0, 0, CANVAS_W, CANVAS_H);

    drawGrid();
    drawPowerUps();
    drawPaddle();
    drawBall();
    drawFlashes();
    drawUI();

    if (gameState === STATE_WAITING) {
      drawWaiting();
    } else if (gameState === STATE_GAMEOVER) {
      drawOverlay('GAME OVER', 'Score: ' + score + '  |  Press Enter to restart', '#ef4444');
    } else if (gameState === STATE_WIN) {
      drawOverlay('YOU WIN!', 'Score: ' + score + '  Level ' + level + '  |  Press Enter to restart', '#22c55e');
    } else if (gameState === STATE_LEVEL_UP) {
      var flashAlpha = 0.4 + 0.2 * Math.sin(gameTime * 8);
      ctx.fillStyle = 'rgba(96,165,250,' + flashAlpha + ')';
      ctx.fillRect(0, 0, CANVAS_W, CANVAS_H);
      ctx.textAlign = 'center';
      ctx.font = 'bold 30px Courier New';
      ctx.fillStyle = '#ffffff';
      ctx.fillText('LEVEL ' + level + ' CLEARED!', CANVAS_W / 2, CANVAS_H / 2 - 16);
      ctx.font = '18px Courier New';
      ctx.fillStyle = '#aaddff';
      ctx.fillText('Level ' + (level + 1) + ' incoming...', CANVAS_W / 2, CANVAS_H / 2 + 16);
      ctx.textAlign = 'left';
    }
  }

  var lastTime = null;

  function gameLoop(timestamp) {
    if (lastTime === null) lastTime = timestamp;
    var dt = Math.min((timestamp - lastTime) / 1000, 0.05);
    lastTime = timestamp;
    gameTime += dt;

    updatePaddle(dt);
    if (gameState === STATE_PLAYING) {
      updateBall(dt);
      updateFlashes(dt);
      updatePowerUps(dt);
      updateRuleTimers(dt);
      // Update high score
      if (score > highScore) {
        highScore = score;
        localStorage.setItem(HIGH_SCORE_KEY, highScore);
      }
    } else if (gameState === STATE_LEVEL_UP) {
      levelUpTimer -= dt;
      if (levelUpTimer <= 0) {
        level++;
        BALL_SPEED = BASE_BALL_SPEED * (1 + (level - 1) * 0.1);
        powerUps = [];
        activePowerUps = {};
        rebuildBricksForLevel();
        initPaddle();
        initBall();
        gameState = STATE_WAITING;
      }
    }

    draw();
    requestAnimationFrame(gameLoop);
  }

  function restartGame() {
    buildGrid();
    score = 0;
    lives = PLAYER_LIVES;
    level = 1;
    BALL_SPEED = BASE_BALL_SPEED;
    gameTime = 0;
    flashes = [];
    powerUps = [];
    activePowerUps = {};
    ballTrail = [];
    levelUpTimer = 0;
    gameState = STATE_WAITING;
    initPaddle();
    initBall();
  }

  buildGrid();
  initPaddle();
  initBall();
  requestAnimationFrame(gameLoop);

})();
</script>
</body>
</html>
