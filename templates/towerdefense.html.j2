{% set OVERLAY_COLOR = '#60a5fa' %}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ game.name }}</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    background: #0d1117;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    font-family: 'Courier New', monospace;
    color: #fff;
    user-select: none;
  }
  h1 { margin-bottom: 8px; font-size: 20px; letter-spacing: 3px; color: #8bc34a; }
  #layout { display: flex; gap: 12px; align-items: flex-start; }
  canvas { border: 2px solid #1e293b; display: block; cursor: crosshair; }
  #panel {
    width: 180px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .stat-box {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 6px;
    padding: 8px 12px;
  }
  .stat-label { font-size: 9px; color: #64748b; letter-spacing: 2px; }
  .stat-val { font-size: 20px; font-weight: bold; color: #e2e8f0; }
  .tower-btn {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 6px;
    padding: 8px 10px;
    cursor: pointer;
    transition: background 0.15s;
    color: #fff;
    font-family: 'Courier New', monospace;
    font-size: 12px;
    text-align: left;
  }
  .tower-btn:hover { background: rgba(255,255,255,0.12); }
  .tower-btn.selected { border-color: #8bc34a; background: rgba(139,195,74,0.15); }
  .tower-btn .t-name { font-weight: bold; font-size: 13px; }
  .tower-btn .t-cost { color: #ffd700; font-size: 11px; }
  .tower-btn .t-stats { color: #94a3b8; font-size: 10px; margin-top: 2px; }
  #wave-btn {
    background: #1b5e20;
    border: 1px solid #4caf50;
    border-radius: 6px;
    padding: 10px;
    cursor: pointer;
    color: #fff;
    font-family: 'Courier New', monospace;
    font-size: 13px;
    font-weight: bold;
    letter-spacing: 1px;
  }
  #wave-btn:hover { background: #2e7d32; }
  #wave-btn:disabled { background: #1a2a1a; border-color: #2d4a2d; color: #4a6a4a; cursor: default; }
  #info { margin-top: 6px; font-size: 10px; color: #475569; text-align: center; }
  #sell-btn {
    background: #7f1d1d;
    border: 1px solid #ef4444;
    border-radius: 6px;
    padding: 8px;
    cursor: pointer;
    color: #fff;
    font-family: 'Courier New', monospace;
    font-size: 12px;
    display: none;
  }
  #sell-btn:hover { background: #991b1b; }
</style>
</head>
<body>
<h1>{{ game.name }}</h1>
<div id="layout">
  <canvas id="gameCanvas" width="{{ game.canvas.width }}" height="{{ game.canvas.height }}"></canvas>
  <div id="panel">
    <div class="stat-box">
      <div class="stat-label">GOLD</div>
      <div class="stat-val" id="goldVal">0</div>
    </div>
    <div class="stat-box">
      <div class="stat-label">LIVES</div>
      <div class="stat-val" id="livesVal">0</div>
    </div>
    <div class="stat-box">
      <div class="stat-label">WAVE</div>
      <div class="stat-val" id="waveVal">0 / {{ game.towerdefense_config.wave_count if game.towerdefense_config and game.towerdefense_config.wave_count else 10 }}</div>
    </div>
    <div class="stat-box">
      <div class="stat-label">SCORE</div>
      <div class="stat-val" id="scoreVal">0</div>
    </div>
    <div style="font-size:11px;color:#64748b;letter-spacing:1px;margin-top:4px;">PLACE TOWER</div>
    {% if game.towerdefense_config and game.towerdefense_config.towers %}
    {% for tower in game.towerdefense_config.towers %}
    <button class="tower-btn" id="tbtn_{{ loop.index0 }}" onclick="selectTower({{ loop.index0 }})">
      <div class="t-name" style="color:{{ tower.color }}">{{ tower.name }}</div>
      <div class="t-cost">💰 {{ tower.cost }} gold</div>
      <div class="t-stats">DMG:{{ tower.damage }} RNG:{{ tower.range }} SPD:{{ tower.fire_rate }}/s</div>
    </button>
    {% endfor %}
    {% endif %}
    <button id="sell-btn" onclick="sellSelected()">💰 Sell Tower</button>
    <button id="wave-btn" onclick="startWave()">▶ START WAVE</button>
  </div>
</div>
<div id="info">Click grid to place tower &nbsp;|&nbsp; Click placed tower to sell</div>
<script>
(function() {
  'use strict';

  var CW = {{ game.canvas.width }};
  var CH = {{ game.canvas.height }};
  var BG = "{{ game.background }}";
  var CELL = {{ game.towerdefense_config.cell_size if game.towerdefense_config and game.towerdefense_config.cell_size else 40 }};

  var GRID_COLS = Math.floor(CW / CELL);
  var GRID_ROWS = Math.floor(CH / CELL);

  var START_GOLD   = {{ game.towerdefense_config.start_gold if game.towerdefense_config and game.towerdefense_config.start_gold else 150 }};
  var START_LIVES  = {{ game.towerdefense_config.start_lives if game.towerdefense_config and game.towerdefense_config.start_lives else 20 }};
  var WAVE_COUNT   = {{ game.towerdefense_config.wave_count if game.towerdefense_config and game.towerdefense_config.wave_count else 10 }};
  var EPW          = {{ game.towerdefense_config.enemies_per_wave if game.towerdefense_config and game.towerdefense_config.enemies_per_wave else 12 }};
  var ENEMY_SPEED  = {{ game.towerdefense_config.enemy_speed if game.towerdefense_config and game.towerdefense_config.enemy_speed else 80 }};
  var ENEMY_HP     = {{ game.towerdefense_config.enemy_hp if game.towerdefense_config and game.towerdefense_config.enemy_hp else 60 }};
  var ENEMY_REWARD = {{ game.towerdefense_config.enemy_reward if game.towerdefense_config and game.towerdefense_config.enemy_reward else 15 }};
  var ENEMY_COLOR  = "{{ game.towerdefense_config.enemy_color if game.towerdefense_config and game.towerdefense_config.enemy_color else '#e53935' }}";
  var PATH_COLOR   = "{{ game.towerdefense_config.path_color if game.towerdefense_config and game.towerdefense_config.path_color else '#8d6e63' }}";
  var GROUND_COLOR = "{{ game.towerdefense_config.ground_color if game.towerdefense_config and game.towerdefense_config.ground_color else '#2e7d32' }}";

  // Tower definitions from model
  var TOWER_DEFS = [
    {% if game.towerdefense_config and game.towerdefense_config.towers %}
    {% for tower in game.towerdefense_config.towers %}
    {
      name: "{{ tower.name }}",
      cost: {{ tower.cost }},
      damage: {{ tower.damage }},
      range: {{ tower.range }},
      fireRate: {{ tower.fire_rate }},
      color: "{{ tower.color }}",
      projColor: "{{ tower.projectile_color if tower.projectile_color else tower.color }}"
    }{% if not loop.last %},{% endif %}
    {% endfor %}
    {% endif %}
  ];

  // ---- Path definition (snake through grid) ----
  // Path is defined as a sequence of [col, row] waypoints
  var PATH_WAYPOINTS = (function() {
    var cols = GRID_COLS, rows = GRID_ROWS;
    // Generate a fixed S-curve path
    var pts = [];
    var r = 1;
    pts.push([0, r]);
    pts.push([cols - 2, r]);
    r = Math.floor(rows * 0.35);
    pts.push([cols - 2, r]);
    pts.push([1, r]);
    r = Math.floor(rows * 0.6);
    pts.push([1, r]);
    pts.push([cols - 2, r]);
    r = rows - 2;
    pts.push([cols - 2, r]);
    pts.push([cols - 1, r]);
    return pts;
  })();

  // Expand waypoints into pixel path
  function buildPath() {
    var path = [];
    for (var i = 0; i < PATH_WAYPOINTS.length; i++) {
      var wp = PATH_WAYPOINTS[i];
      path.push({
        x: wp[0] * CELL + CELL / 2,
        y: wp[1] * CELL + CELL / 2
      });
    }
    return path;
  }

  // Compute which grid cells are on the path
  function buildPathCells() {
    var cells = {};
    for (var i = 0; i < PATH_WAYPOINTS.length - 1; i++) {
      var a = PATH_WAYPOINTS[i], b = PATH_WAYPOINTS[i + 1];
      var dc = b[0] - a[0], dr = b[1] - a[1];
      var steps = Math.max(Math.abs(dc), Math.abs(dr));
      for (var s = 0; s <= steps; s++) {
        var c = a[0] + Math.round(dc * s / steps);
        var r = a[1] + Math.round(dr * s / steps);
        cells[c + ',' + r] = true;
      }
    }
    return cells;
  }

  var PATH_POINTS = buildPath();
  var PATH_CELLS  = buildPathCells();

  function isPathCell(col, row) {
    return !!PATH_CELLS[col + ',' + row];
  }

  // ---- State ----
  var gold, lives, score, wave, gameState;
  var grid;       // grid[row][col] = null | tower object
  var enemies, projectiles, particles;
  var waveActive, spawnQueue, spawnTimer, spawnInterval;
  var selectedTowerType = 0;
  var selectedCell = null;  // {col, row} of selected placed tower

  var goldEl  = document.getElementById('goldVal');
  var livesEl = document.getElementById('livesVal');
  var waveEl  = document.getElementById('waveVal');
  var scoreEl = document.getElementById('scoreVal');
  var waveBtnEl = document.getElementById('wave-btn');
  var sellBtnEl = document.getElementById('sell-btn');

  function updateHUD() {
    goldEl.textContent  = gold;
    livesEl.textContent = lives;
    waveEl.textContent  = wave + ' / ' + WAVE_COUNT;
    scoreEl.textContent = score;
  }

{% include '_behavior_dsl.j2' %}
  function _ruleHook_loseLife()           { lives = Math.max(0, lives - 1); if (lives <= 0) { gameState = 'gameover'; } }
  function _ruleHook_addPoints(pts)       { score += pts; gold += pts; }
  function _ruleHook_destroyEnemy()       { /* handled per-tick */ }
  function _ruleHook_destroyAllEnemies()  { enemies.length = 0; }
  function _ruleHook_nextLevel()          { wave++; }
  function _ruleHook_spawn(e, l)          { /* managed by wave system */ }

  function initGame() {
    gold = START_GOLD; lives = START_LIVES; score = 0; wave = 0;
    gameState = 'idle';
    grid = [];
    for (var r = 0; r < GRID_ROWS; r++) {
      grid[r] = [];
      for (var c = 0; c < GRID_COLS; c++) grid[r][c] = null;
    }
    enemies = []; projectiles = []; particles = [];
    waveActive = false; spawnQueue = 0; spawnTimer = 0;
    selectedCell = null;
    updateHUD();
    waveBtnEl.disabled = false;
    sellBtnEl.style.display = 'none';
  }

  // ---- Tower selection (global for onclick) ----
  window.selectTower = function(idx) {
    selectedTowerType = idx;
    selectedCell = null;
    sellBtnEl.style.display = 'none';
    var btns = document.querySelectorAll('.tower-btn');
    for (var i = 0; i < btns.length; i++) {
      btns[i].classList.toggle('selected', i === idx);
    }
  };

  window.sellSelected = function() {
    if (!selectedCell) return;
    var t = grid[selectedCell.row][selectedCell.col];
    if (!t) return;
    var refund = Math.floor(t.def.cost * 0.6);
    gold += refund;
    grid[selectedCell.row][selectedCell.col] = null;
    selectedCell = null;
    sellBtnEl.style.display = 'none';
    updateHUD();
  };

  window.startWave = function() {
    if (waveActive || wave >= WAVE_COUNT || gameState === 'gameover' || gameState === 'win') return;
    wave++;
    var hp = Math.floor(ENEMY_HP * (1 + (wave - 1) * 0.3));
    var speed = ENEMY_SPEED * (1 + (wave - 1) * 0.05);
    var count = EPW + Math.floor((wave - 1) * 2);
    spawnQueue = count;
    spawnTimer = 0;
    spawnInterval = 0.8;
    waveActive = true;
    waveBtnEl.disabled = true;
    updateHUD();
    // Store wave params for spawning
    window._waveHP = hp;
    window._waveSpeed = speed;
  };

  // ---- Canvas click ----
  var canvas = document.getElementById('gameCanvas');
  canvas.addEventListener('click', function(e) {
    if (gameState === 'gameover' || gameState === 'win') { initGame(); return; }
    var rect = canvas.getBoundingClientRect();
    var mx = e.clientX - rect.left;
    var my = e.clientY - rect.top;
    var col = Math.floor(mx / CELL);
    var row = Math.floor(my / CELL);
    if (col < 0 || col >= GRID_COLS || row < 0 || row >= GRID_ROWS) return;

    // Click on existing tower → select it
    if (grid[row][col]) {
      selectedCell = { col: col, row: row };
      sellBtnEl.style.display = 'block';
      return;
    }

    // Deselect sell
    selectedCell = null;
    sellBtnEl.style.display = 'none';

    // Can't place on path
    if (isPathCell(col, row)) return;

    // Place tower
    var def = TOWER_DEFS[selectedTowerType];
    if (!def) return;
    if (gold < def.cost) return;
    gold -= def.cost;
    grid[row][col] = {
      def: def,
      col: col, row: row,
      x: col * CELL + CELL / 2,
      y: row * CELL + CELL / 2,
      fireTimer: 0,
      target: null
    };
    updateHUD();
  });

  // ---- Enemy spawning ----
  function spawnEnemy() {
    var start = PATH_POINTS[0];
    enemies.push({
      x: start.x, y: start.y,
      hp: window._waveHP,
      maxHp: window._waveHP,
      speed: window._waveSpeed,
      pathIdx: 0,
      alive: true,
      reachedEnd: false
    });
  }

  // ---- Update ----
  function updateSpawn(dt) {
    if (!waveActive) return;
    if (spawnQueue > 0) {
      spawnTimer -= dt;
      if (spawnTimer <= 0) {
        spawnEnemy();
        spawnQueue--;
        spawnTimer = spawnInterval;
      }
    }
    // Wave ends when no enemies left and queue empty
    if (spawnQueue <= 0 && enemies.length === 0) {
      waveActive = false;
      if (wave >= WAVE_COUNT) {
        gameState = 'win';
      } else {
        waveBtnEl.disabled = false;
      }
    }
  }

  function updateEnemies(dt) {
    for (var i = enemies.length - 1; i >= 0; i--) {
      var e = enemies[i];
      if (!e.alive) { enemies.splice(i, 1); continue; }
      if (e.reachedEnd) {
        lives--;
        if (lives <= 0) { gameState = 'gameover'; lives = 0; }
        enemies.splice(i, 1);
        updateHUD();
        continue;
      }

      // Move along path
      var target = PATH_POINTS[e.pathIdx + 1];
      if (!target) { e.reachedEnd = true; continue; }
      var dx = target.x - e.x, dy = target.y - e.y;
      var dist = Math.sqrt(dx*dx + dy*dy);
      var step = e.speed * dt;
      if (step >= dist) {
        e.x = target.x; e.y = target.y;
        e.pathIdx++;
        if (e.pathIdx >= PATH_POINTS.length - 1) e.reachedEnd = true;
      } else {
        e.x += dx / dist * step;
        e.y += dy / dist * step;
      }
    }
  }

  function updateTowers(dt) {
    for (var r = 0; r < GRID_ROWS; r++) {
      for (var c = 0; c < GRID_COLS; c++) {
        var t = grid[r][c];
        if (!t) continue;
        t.fireTimer -= dt;

        // Find nearest enemy in range
        var best = null, bestDist = Infinity;
        var rangePixels = t.def.range * CELL;
        for (var i = 0; i < enemies.length; i++) {
          var e = enemies[i];
          if (!e.alive) continue;
          var dx = e.x - t.x, dy = e.y - t.y;
          var d = Math.sqrt(dx*dx + dy*dy);
          if (d <= rangePixels && d < bestDist) {
            bestDist = d; best = e;
          }
        }
        t.target = best;

        if (best && t.fireTimer <= 0) {
          t.fireTimer = 1 / t.def.fireRate;
          projectiles.push({
            x: t.x, y: t.y,
            target: best,
            speed: 280,
            damage: t.def.damage,
            color: t.def.projColor,
            alive: true
          });
        }
      }
    }
  }

  function updateProjectiles(dt) {
    for (var i = projectiles.length - 1; i >= 0; i--) {
      var p = projectiles[i];
      if (!p.alive || !p.target || !p.target.alive) {
        projectiles.splice(i, 1); continue;
      }
      var dx = p.target.x - p.x, dy = p.target.y - p.y;
      var dist = Math.sqrt(dx*dx + dy*dy);
      var step = p.speed * dt;
      if (step >= dist) {
        // Hit!
        p.target.hp -= p.damage;
        spawnHitParticle(p.target.x, p.target.y, p.color);
        if (p.target.hp <= 0) {
          p.target.alive = false;
          gold += ENEMY_REWARD;
          score += ENEMY_REWARD * 5;
          updateHUD();
          spawnDeathParticles(p.target.x, p.target.y);
        }
        projectiles.splice(i, 1);
      } else {
        p.x += dx / dist * step;
        p.y += dy / dist * step;
      }
    }
  }

  function spawnHitParticle(x, y, color) {
    particles.push({ x:x, y:y, vx:0, vy:-40, life:0.2, maxLife:0.2, color:color, r:4 });
  }

  function spawnDeathParticles(x, y) {
    for (var i = 0; i < 8; i++) {
      var a = Math.PI * 2 * i / 8;
      particles.push({
        x:x, y:y,
        vx: Math.cos(a)*80, vy: Math.sin(a)*80 - 40,
        life:0.4, maxLife:0.4, color:ENEMY_COLOR, r:3
      });
    }
  }

  function updateParticles(dt) {
    for (var i = particles.length - 1; i >= 0; i--) {
      var p = particles[i];
      p.x += p.vx * dt; p.y += p.vy * dt;
      p.vy += 200 * dt;
      p.life -= dt;
      if (p.life <= 0) particles.splice(i, 1);
    }
  }

  function update(dt) {
    if (gameState !== 'idle' && gameState !== 'playing') return;
    gameState = 'playing';
    updateSpawn(dt);
    updateEnemies(dt);
    updateTowers(dt);
    updateProjectiles(dt);
    updateParticles(dt);
    updateRuleTimers(dt);
  }

  // ---- Drawing ----
  var ctx = canvas.getContext('2d');

  var _RT_W = CW;
  var _RT_H = CH;
{% include '_runtime.j2' %}
  function drawGrid() {
    // Background
    ctx.fillStyle = GROUND_COLOR;
    ctx.fillRect(0, 0, CW, CH);

    // Path cells
    for (var key in PATH_CELLS) {
      var parts = key.split(',');
      var c = parseInt(parts[0]), r = parseInt(parts[1]);
      ctx.fillStyle = PATH_COLOR;
      ctx.fillRect(c * CELL, r * CELL, CELL, CELL);
    }

    // Grid lines
    ctx.strokeStyle = 'rgba(0,0,0,0.2)';
    ctx.lineWidth = 1;
    for (var r = 0; r < GRID_ROWS; r++) {
      for (var c = 0; c < GRID_COLS; c++) {
        ctx.strokeRect(c * CELL, r * CELL, CELL, CELL);
      }
    }

    // Path arrows
    ctx.strokeStyle = 'rgba(255,255,255,0.15)';
    ctx.lineWidth = 2;
    for (var i = 0; i < PATH_POINTS.length - 1; i++) {
      var a = PATH_POINTS[i], b = PATH_POINTS[i+1];
      ctx.beginPath();
      ctx.moveTo(a.x, a.y);
      ctx.lineTo(b.x, b.y);
      ctx.stroke();
    }

    // Start / End markers
    var s = PATH_POINTS[0], en = PATH_POINTS[PATH_POINTS.length-1];
    ctx.fillStyle = '#4caf50';
    ctx.font = 'bold 11px Courier New';
    ctx.textAlign = 'center';
    ctx.fillText('START', s.x, s.y + 4);
    ctx.fillStyle = '#ef4444';
    ctx.fillText('END', en.x, en.y + 4);
    ctx.textAlign = 'left';
  }

  function drawTowers(t) {
    for (var r = 0; r < GRID_ROWS; r++) {
      for (var c = 0; c < GRID_COLS; c++) {
        var tower = grid[r][c];
        if (!tower) continue;
        var px = c * CELL, py = r * CELL;
        var isSelected = selectedCell && selectedCell.col === c && selectedCell.row === r;

        // Base
        ctx.fillStyle = '#1e293b';
        ctx.fillRect(px + 2, py + 2, CELL - 4, CELL - 4);

        // Tower body
        ctx.save();
        ctx.shadowColor = tower.def.color;
        ctx.shadowBlur = isSelected ? 16 : 6;
        ctx.fillStyle = tower.def.color;
        var cs = CELL * 0.35;
        ctx.fillRect(px + CELL/2 - cs, py + CELL/2 - cs, cs*2, cs*2);
        ctx.restore();

        // Range ring (when selected or hovered)
        if (isSelected) {
          ctx.strokeStyle = 'rgba(255,255,255,0.25)';
          ctx.lineWidth = 1;
          ctx.setLineDash([4, 4]);
          ctx.beginPath();
          ctx.arc(tower.x, tower.y, tower.def.range * CELL, 0, Math.PI * 2);
          ctx.stroke();
          ctx.setLineDash([]);
        }

        // Barrel pointing at target
        if (tower.target) {
          var dx = tower.target.x - tower.x, dy = tower.target.y - tower.y;
          var angle = Math.atan2(dy, dx);
          ctx.save();
          ctx.translate(tower.x, tower.y);
          ctx.rotate(angle);
          ctx.fillStyle = tower.def.color;
          ctx.fillRect(0, -3, CELL * 0.4, 6);
          ctx.restore();
        }
      }
    }
  }

  function drawEnemies() {
    for (var i = 0; i < enemies.length; i++) {
      var e = enemies[i];
      if (!e.alive) continue;
      var r = 10;
      // Body
      ctx.save();
      ctx.shadowColor = ENEMY_COLOR;
      ctx.shadowBlur = 8;
      ctx.fillStyle = ENEMY_COLOR;
      ctx.beginPath();
      ctx.arc(e.x, e.y, r, 0, Math.PI * 2);
      ctx.fill();
      ctx.restore();
      // HP bar
      var barW = 24, barH = 4;
      var hpFrac = e.hp / e.maxHp;
      ctx.fillStyle = '#1a1a1a';
      ctx.fillRect(e.x - barW/2, e.y - r - 7, barW, barH);
      ctx.fillStyle = hpFrac > 0.5 ? '#4caf50' : hpFrac > 0.25 ? '#ff9800' : '#f44336';
      ctx.fillRect(e.x - barW/2, e.y - r - 7, barW * hpFrac, barH);
    }
  }

  function drawProjectiles() {
    for (var i = 0; i < projectiles.length; i++) {
      var p = projectiles[i];
      ctx.save();
      ctx.shadowColor = p.color;
      ctx.shadowBlur = 10;
      ctx.fillStyle = p.color;
      ctx.beginPath();
      ctx.arc(p.x, p.y, 4, 0, Math.PI * 2);
      ctx.fill();
      ctx.restore();
    }
  }

  function drawParticles() {
    for (var i = 0; i < particles.length; i++) {
      var p = particles[i];
      var alpha = p.life / p.maxLife;
      ctx.globalAlpha = alpha;
      ctx.fillStyle = p.color;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r * alpha, 0, Math.PI * 2);
      ctx.fill();
    }
    ctx.globalAlpha = 1;
  }

  function drawPlacementPreview() {
    // Show range preview for selected tower type when hovering
    // (handled via mousemove)
  }

  var hoverCell = null;
  canvas.addEventListener('mousemove', function(e) {
    var rect = canvas.getBoundingClientRect();
    var mx = e.clientX - rect.left, my = e.clientY - rect.top;
    hoverCell = { col: Math.floor(mx / CELL), row: Math.floor(my / CELL) };
  });
  canvas.addEventListener('mouseleave', function() { hoverCell = null; });

  function drawHoverPreview() {
    if (!hoverCell) return;
    var c = hoverCell.col, r = hoverCell.row;
    if (c < 0 || c >= GRID_COLS || r < 0 || r >= GRID_ROWS) return;
    if (grid[r][c] || isPathCell(c, r)) {
      ctx.fillStyle = 'rgba(239,68,68,0.2)';
      ctx.fillRect(c * CELL, r * CELL, CELL, CELL);
      return;
    }
    var def = TOWER_DEFS[selectedTowerType];
    if (!def) return;
    var canAfford = gold >= def.cost;
    ctx.fillStyle = canAfford ? 'rgba(139,195,74,0.2)' : 'rgba(239,68,68,0.15)';
    ctx.fillRect(c * CELL, r * CELL, CELL, CELL);
    // Range preview
    ctx.strokeStyle = canAfford ? 'rgba(139,195,74,0.3)' : 'rgba(239,68,68,0.2)';
    ctx.lineWidth = 1;
    ctx.setLineDash([3, 3]);
    ctx.beginPath();
    ctx.arc(c * CELL + CELL/2, r * CELL + CELL/2, def.range * CELL, 0, Math.PI * 2);
    ctx.stroke();
    ctx.setLineDash([]);
  }

  var lastTime = null;
  function gameLoop(ts) {
    if (lastTime === null) lastTime = ts;
    var dt = Math.min((ts - lastTime) / 1000, 0.05);
    lastTime = ts;

    update(dt);

    drawGrid();
    drawTowers(ts / 1000);
    drawEnemies();
    drawProjectiles();
    drawParticles();
    drawHoverPreview();

    if (gameState === 'gameover') {
      drawOverlay('GAME OVER', 'Score: ' + score + '  |  Wave ' + wave + ' / ' + WAVE_COUNT, '#ef4444');
    } else if (gameState === 'win') {
      drawOverlay('VICTORY!', 'Score: ' + score + '  |  All waves survived!', '#ffd700');
    }

    requestAnimationFrame(gameLoop);
  }

  // Init first tower button selected
  if (TOWER_DEFS.length > 0) {
    var firstBtn = document.getElementById('tbtn_0');
    if (firstBtn) firstBtn.classList.add('selected');
  }

  initGame();
  requestAnimationFrame(gameLoop);

})();
</script>
</body>
</html>
