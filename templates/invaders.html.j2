{% set OVERLAY_COLOR = '#00ff41' %}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ game.name }}</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    background: #000;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    font-family: 'Courier New', monospace;
    color: #00ff41;
  }
  h1 { margin-bottom: 10px; font-size: 24px; color: #00ff41; letter-spacing: 4px; }
  canvas { border: 2px solid #00ff41; display: block; }
  #info { margin-top: 8px; font-size: 13px; color: #005511; }
</style>
</head>
<body>
<h1>{{ game.name }}</h1>
<canvas id="gameCanvas" width="{{ game.canvas.width }}" height="{{ game.canvas.height }}"></canvas>
<div id="info">← → / A D to move &nbsp;|&nbsp; Space to shoot &nbsp;|&nbsp; Enter to restart</div>
<script>
(function() {
  'use strict';

  var CELL = {{ game.map.cell_size }};
  var CANVAS_W = {{ game.canvas.width }};
  var CANVAS_H = {{ game.canvas.height }};
  var BG_COLOR = "{{ game.background }}";
  var PLAYER_COLOR = "{{ game.player.color }}";
  var PLAYER_LIVES = {{ game.player.lives if game.player.lives else 3 }};
  var PLAYER_SPEED = {{ game.player.speed }};
  var SHOOT_COOLDOWN = {{ game.player.shoot.cooldown if game.player.shoot else 0.4 }};

  var TILE_MAP = {};
  {% if game.tiles %}{% for tile in game.tiles.tiles %}
  TILE_MAP["{{ tile.symbol }}"] = { solid: {{ 'true' if tile.solid else 'false' }}, color: "{{ tile.color or '#000' }}", name: "{{ tile.name }}" };
  {% endfor %}{% endif %}

  var RAW_LAYOUT = [{% for row in game.map.layout %}{{ row | tojson }}{% if not loop.last %},{% endif %}{% endfor %}];

  var PLAYER_SPAWN = { col: {{ player_spawn.col }}, row: {{ player_spawn.row }} };
  var PROJECTILE_SPEED = {{ projectiles[0].speed if projectiles else 16 }};
  var PROJECTILE_COLOR = "{{ projectiles[0].color if projectiles else '#0f0' }}";

  var ENEMY_TYPES = [{% for e in enemies %}{
    name: {{ e.name | tojson }}, color: "{{ e.color }}", points: {{ e.points or 100 }},
    spawnPositions: [{% for p in e._spawn_positions %}{ col: {{ p.col }}, row: {{ p.row }} }{% if not loop.last %},{% endif %}{% endfor %}]
  }{% if not loop.last %},{% endif %}{% endfor %}];

  var HIGH_SCORE_KEY = 'invaders_high_score_{{ game.name | replace(" ", "_") }}';
  var highScore = parseInt(localStorage.getItem(HIGH_SCORE_KEY) || '0', 10);

  var canvas = document.getElementById('gameCanvas');
  var ctx = canvas.getContext('2d');

  var ROWS = RAW_LAYOUT.length;
  var COLS = RAW_LAYOUT[0].length;

  var STATE_PLAYING  = 'PLAYING';
  var STATE_GAMEOVER = 'GAME_OVER';
  var STATE_WIN      = 'WIN';

  // Grid
  var grid = [];
  // Barrier damage map: key = "row,col" -> hits remaining (3)
  var barrierHits = {};
  var barrierOriginalHits = {};  // for regeneration

  // Mystery ship
  var mysteryShip = null;
  var mysteryShipTimer = 15 + Math.random() * 15;  // first appearance
  var MYSTERY_SHIP_SPEED = CELL * 5;
  var wave = 1;

{% include '_behavior_dsl.j2' %}
  var _RT_W = CANVAS_W;
  var _RT_H = CANVAS_H;
{% include '_runtime.j2' %}
  function _ruleHook_loseLife()           { lives = Math.max(0, lives - 1); if (lives <= 0) { gameState = STATE_GAMEOVER; } }
  function _ruleHook_addPoints(pts)       { score += pts; }
  function _ruleHook_destroyEnemy()       { /* handled per-tick */ }
  function _ruleHook_destroyAllEnemies()  { aliens.length = 0; }
  function _ruleHook_nextLevel()          { wave++; initInvaders(); }
  function _ruleHook_spawn(e, l)          { /* no dynamic spawn */ }

  function buildGrid() {
    grid = [];
    barrierHits = {};
    barrierOriginalHits = {};
    for (var r = 0; r < ROWS; r++) {
      grid[r] = [];
      for (var c = 0; c < COLS; c++) {
        var ch = (RAW_LAYOUT[r][c] !== undefined) ? RAW_LAYOUT[r][c] : '.';
        var tile = TILE_MAP[ch] || { solid: false, color: BG_COLOR, name: 'empty' };
        var isBarrier = (ch === '^' || ch === '-');
        grid[r][c] = {
          symbol: ch,
          solid: tile.solid,
          color: tile.color,
          originalColor: tile.color,
          name: tile.name,
          isBarrier: isBarrier,
          destroyed: false
        };
        if (isBarrier) {
          barrierHits[r + ',' + c] = 3;
          barrierOriginalHits[r + ',' + c] = 3;
        }
      }
    }
  }

  function regenerateBarriers() {
    // Slowly restore barrier health between waves
    for (var key in barrierOriginalHits) {
      var parts = key.split(',');
      var r = parseInt(parts[0]);
      var c = parseInt(parts[1]);
      var cell = grid[r][c];
      if (!cell) continue;
      if (cell.destroyed) {
        // Restore destroyed barriers
        cell.destroyed = false;
        cell.solid = true;
        barrierHits[key] = 1;
        cell.color = '#004411';
      } else if (barrierHits[key] !== undefined && barrierHits[key] < 3) {
        barrierHits[key]++;
        if (barrierHits[key] === 2) cell.color = '#009922';
        else if (barrierHits[key] === 3) cell.color = cell.originalColor;
      }
    }
  }

  function isSolid(col, row) {
    if (row < 0 || row >= ROWS || col < 0 || col >= COLS) return true;
    var cell = grid[row][col];
    if (cell.isBarrier && cell.destroyed) return false;
    return cell.solid;
  }

  function isBarrierCell(col, row) {
    if (row < 0 || row >= ROWS || col < 0 || col >= COLS) return false;
    var cell = grid[row][col];
    return cell.isBarrier && !cell.destroyed;
  }

  function damageBarrier(col, row) {
    var key = row + ',' + col;
    if (barrierHits[key] === undefined) return false;
    barrierHits[key]--;
    if (barrierHits[key] <= 0) {
      grid[row][col].destroyed = true;
      grid[row][col].solid = false;
      delete barrierHits[key];
    } else {
      // Darken color
      var hits = barrierHits[key];
      if (hits === 2) grid[row][col].color = '#009922';
      else if (hits === 1) grid[row][col].color = '#004411';
    }
    return true;
  }

  // Player
  var player = {};
  var playerBullet = null;
  var shootTimer = 0;
  var invincTimer = 0;

  // Invaders
  var invaders = [];
  var formationDx = 1;   // pixels per frame step direction
  var formationX = 0;    // offset from initial positions
  var formationY = 0;
  var formationStepTimer = 0;
  var formationStepInterval = 0.8; // seconds between steps
  var formationStepSize = 6;       // pixels per step
  var formationDescendSize = CELL; // pixels to descend when hitting wall
  var killedCount = 0;
  var totalInvaders = 0;

  // Enemy bullets
  var enemyBullets = [];
  var enemyShootTimer = 0;
  var enemyShootInterval = 2.0;

  // Explosions
  var explosions = [];

  var score = 0;
  var lives = PLAYER_LIVES;
  var gameState = STATE_PLAYING;
  var gameTime = 0;

  // Wall boundaries (leftmost and rightmost non-wall columns)
  var leftBound = CELL;
  var rightBound = (COLS - 1) * CELL;

  function initPlayer() {
    player = {
      x: PLAYER_SPAWN.col * CELL + CELL / 2,
      y: PLAYER_SPAWN.row * CELL + CELL / 2,
      w: CELL * 0.9,
      h: CELL * 0.5
    };
  }

  function initInvaders() {
    invaders = [];
    totalInvaders = 0;
    killedCount = 0;
    formationDx = 1;
    formationX = 0;
    formationY = 0;
    formationStepTimer = 0;
    formationStepInterval = 0.8;

    for (var t = 0; t < ENEMY_TYPES.length; t++) {
      var type = ENEMY_TYPES[t];
      for (var s = 0; s < type.spawnPositions.length; s++) {
        var sp = type.spawnPositions[s];
        // Determine row color: top rows cyan, middle magenta, bottom yellow
        var rowIdx = sp.row - 2; // relative row in formation
        var rowColor = type.color;
        if (rowIdx === 0) rowColor = '#00ffff';
        else if (rowIdx === 1) rowColor = '#ff00ff';
        else rowColor = '#ffff00';

        invaders.push({
          baseCol: sp.col,
          baseRow: sp.row,
          color: rowColor,
          points: type.points,
          alive: true,
          flashTimer: 0
        });
        totalInvaders++;
      }
    }
  }

  document.addEventListener('keydown', function(e) {
    keys[e.key] = true;
    if ((gameState === STATE_GAMEOVER || gameState === STATE_WIN) &&
        (e.key === 'Enter' || e.key === ' ')) {
      e.preventDefault();
      restartGame();
      return;
    }
    if (e.key === ' ' || e.key === 'ArrowLeft' || e.key === 'ArrowRight' ||
        e.key === 'a' || e.key === 'd') {
      e.preventDefault();
    }
  });

  function updatePlayer(dt) {
    var speed = PLAYER_SPEED * CELL * dt;
    if (keys['ArrowLeft'] || keys['a']) {
      player.x -= speed;
    }
    if (keys['ArrowRight'] || keys['d']) {
      player.x += speed;
    }
    // Clamp within wall boundaries
    player.x = Math.max(leftBound + player.w / 2, Math.min(rightBound - player.w / 2, player.x));
  }

  function updateShooting(dt) {
    if (shootTimer > 0) shootTimer -= dt;
    if (keys[' '] && shootTimer <= 0 && playerBullet === null) {
      shootTimer = SHOOT_COOLDOWN;
      playerBullet = {
        x: player.x,
        y: player.y - CELL * 0.3,
        speed: PROJECTILE_SPEED * CELL,
        alive: true
      };
    }
  }

  function updatePlayerBullet(dt) {
    if (!playerBullet) return;
    playerBullet.y -= playerBullet.speed * dt;

    // Off screen
    if (playerBullet.y < 0) { playerBullet = null; return; }

    // Hit barrier
    var bc = Math.floor(playerBullet.x / CELL);
    var br = Math.floor(playerBullet.y / CELL);
    if (isBarrierCell(bc, br)) {
      damageBarrier(bc, br);
      playerBullet = null;
      return;
    }

    // Hit wall
    if (isSolid(bc, br)) { playerBullet = null; return; }

    // Hit invader
    for (var i = 0; i < invaders.length; i++) {
      var inv = invaders[i];
      if (!inv.alive) continue;
      var ix = (inv.baseCol * CELL + CELL / 2) + formationX;
      var iy = (inv.baseRow * CELL + CELL / 2) + formationY;
      var hw = CELL * 0.4;
      var hh = CELL * 0.35;
      if (playerBullet.x > ix - hw && playerBullet.x < ix + hw &&
          playerBullet.y > iy - hh && playerBullet.y < iy + hh) {
        inv.alive = false;
        inv.flashTimer = 0.3;
        score += inv.points;
        killedCount++;
        playerBullet = null;
        // Speed up formation
        if (killedCount % 10 === 0) {
          formationStepInterval = Math.max(0.1, formationStepInterval * 0.8);
        }
        checkWin();
        return;
      }
    }
  }

  function updateFormation(dt) {
    formationStepTimer += dt;
    if (formationStepTimer < formationStepInterval) return;
    formationStepTimer -= formationStepInterval;

    // Find leftmost and rightmost alive invader
    var minX = Infinity, maxX = -Infinity;
    for (var i = 0; i < invaders.length; i++) {
      if (!invaders[i].alive) continue;
      var ix = (invaders[i].baseCol * CELL + CELL / 2) + formationX;
      if (ix < minX) minX = ix;
      if (ix > maxX) maxX = ix;
    }

    // Check if next step would hit wall
    var nextX = formationX + formationDx * formationStepSize;
    var nextMin = minX - formationX + nextX;
    var nextMax = maxX - formationX + nextX;

    if (nextMin < leftBound + CELL * 0.5 || nextMax > rightBound - CELL * 0.5) {
      // Descend and reverse
      formationY += formationDescendSize;
      formationDx = -formationDx;
    } else {
      formationX += formationDx * formationStepSize;
    }

    // Check if any invader reached player row
    for (var j = 0; j < invaders.length; j++) {
      if (!invaders[j].alive) continue;
      var iy = (invaders[j].baseRow * CELL + CELL / 2) + formationY;
      if (iy >= player.y - CELL) {
        gameState = STATE_GAMEOVER;
        return;
      }
    }
  }

  function updateEnemyShooting(dt) {
    enemyShootTimer -= dt;
    if (enemyShootTimer > 0) return;
    enemyShootTimer = enemyShootInterval + Math.random() * 1.0;

    // Pick a random alive invader in the bottom row of each column
    var colMap = {};
    for (var i = 0; i < invaders.length; i++) {
      var inv = invaders[i];
      if (!inv.alive) continue;
      var col = inv.baseCol;
      if (!colMap[col] || inv.baseRow > colMap[col].baseRow) {
        colMap[col] = inv;
      }
    }
    var shooters = [];
    for (var k in colMap) shooters.push(colMap[k]);
    if (shooters.length === 0) return;

    var shooter = shooters[Math.floor(Math.random() * shooters.length)];
    var sx = (shooter.baseCol * CELL + CELL / 2) + formationX;
    var sy = (shooter.baseRow * CELL + CELL / 2) + formationY;
    enemyBullets.push({
      x: sx,
      y: sy,
      speed: PROJECTILE_SPEED * CELL * 0.5,
      alive: true
    });
  }

  function updateEnemyBullets(dt) {
    for (var i = enemyBullets.length - 1; i >= 0; i--) {
      var b = enemyBullets[i];
      b.y += b.speed * dt;

      // Off screen
      if (b.y > CANVAS_H) { enemyBullets.splice(i, 1); continue; }

      // Hit barrier
      var bc = Math.floor(b.x / CELL);
      var br = Math.floor(b.y / CELL);
      if (isBarrierCell(bc, br)) {
        damageBarrier(bc, br);
        enemyBullets.splice(i, 1);
        continue;
      }

      // Hit player
      if (invincTimer <= 0) {
        var dx = b.x - player.x;
        var dy = b.y - player.y;
        if (Math.abs(dx) < player.w / 2 && Math.abs(dy) < player.h / 2 + CELL * 0.2) {
          enemyBullets.splice(i, 1);
          lives--;
          invincTimer = 1.5;
          if (lives <= 0) {
            gameState = STATE_GAMEOVER;
          }
          continue;
        }
      }
    }
  }

  function updateExplosions(dt) {
    for (var i = explosions.length - 1; i >= 0; i--) {
      explosions[i].timer -= dt;
      if (explosions[i].timer <= 0) explosions.splice(i, 1);
    }
    for (var j = 0; j < invaders.length; j++) {
      if (invaders[j].flashTimer > 0) invaders[j].flashTimer -= dt;
    }
  }

  function checkWin() {
    for (var i = 0; i < invaders.length; i++) {
      if (invaders[i].alive) return;
    }
    // Wave cleared — regenerate barriers and start next wave
    wave++;
    regenerateBarriers();
    formationStepInterval = Math.max(0.1, 0.8 * Math.pow(0.85, wave - 1));
    enemyShootInterval = Math.max(0.5, 2.0 - (wave - 1) * 0.2);
    playerBullet = null;
    enemyBullets = [];
    initInvaders();
    // If 5 waves cleared, win
    if (wave > 5) {
      gameState = STATE_WIN;
    }
  }

  function updateMysteryShip(dt) {
    mysteryShipTimer -= dt;
    if (mysteryShipTimer <= 0 && !mysteryShip) {
      // Spawn mystery ship
      var dir = Math.random() > 0.5 ? 1 : -1;
      mysteryShip = {
        x: dir > 0 ? -CELL : CANVAS_W + CELL,
        y: CELL * 1.5,
        dir: dir,
        speed: MYSTERY_SHIP_SPEED,
        points: 50 + Math.floor(Math.random() * 6) * 50  // 50-300
      };
      mysteryShipTimer = 20 + Math.random() * 20;
    }
    if (mysteryShip) {
      mysteryShip.x += mysteryShip.dir * mysteryShip.speed * dt;
      // Off screen
      if (mysteryShip.x < -CELL * 2 || mysteryShip.x > CANVAS_W + CELL * 2) {
        mysteryShip = null;
      }
      // Hit by player bullet
      if (playerBullet) {
        var mx = mysteryShip ? mysteryShip.x : -9999;
        var my = mysteryShip ? mysteryShip.y : -9999;
        if (Math.abs(playerBullet.x - mx) < CELL && Math.abs(playerBullet.y - my) < CELL * 0.5) {
          score += mysteryShip.points;
          // Flash score
          explosions.push({ x: mx, y: my, text: '+' + mysteryShip.points, timer: 0.8 });
          mysteryShip = null;
          playerBullet = null;
        }
      }
    }
  }

  function drawMysteryShip() {
    if (!mysteryShip) return;
    var x = mysteryShip.x;
    var y = mysteryShip.y;
    var s = CELL * 0.5;
    ctx.save();
    ctx.shadowColor = '#ff0000';
    ctx.shadowBlur = 12;
    ctx.fillStyle = '#ff0000';
    // Simple saucer shape
    ctx.beginPath();
    ctx.ellipse(x, y, s * 1.5, s * 0.5, 0, 0, Math.PI * 2);
    ctx.fill();
    ctx.fillStyle = '#ff6666';
    ctx.beginPath();
    ctx.ellipse(x, y - s * 0.3, s * 0.7, s * 0.4, 0, 0, Math.PI * 2);
    ctx.fill();
    ctx.restore();
  }

  // Drawing
  function drawGrid() {
    for (var r = 0; r < ROWS; r++) {
      for (var c = 0; c < COLS; c++) {
        var cell = grid[r][c];
        var px = c * CELL;
        var py = r * CELL;
        if (cell.solid && !cell.destroyed) {
          ctx.fillStyle = cell.color;
          ctx.fillRect(px, py, CELL, CELL);
        }
      }
    }
  }

  function drawInvader(x, y, color, rowIdx) {
    var s = CELL * 0.38;
    ctx.fillStyle = color;

    // Body (3x2 grid of pixels)
    ctx.fillRect(x - s, y - s * 0.5, s * 2, s);

    // Antennae
    ctx.fillRect(x - s * 0.7, y - s * 1.1, s * 0.25, s * 0.6);
    ctx.fillRect(x + s * 0.45, y - s * 1.1, s * 0.25, s * 0.6);

    // Legs
    ctx.fillRect(x - s * 1.1, y + s * 0.3, s * 0.3, s * 0.5);
    ctx.fillRect(x + s * 0.8, y + s * 0.3, s * 0.3, s * 0.5);

    // Eyes (white dots)
    ctx.fillStyle = '#000';
    ctx.fillRect(x - s * 0.5, y - s * 0.3, s * 0.3, s * 0.3);
    ctx.fillRect(x + s * 0.2, y - s * 0.3, s * 0.3, s * 0.3);
  }

  function drawInvaders() {
    for (var i = 0; i < invaders.length; i++) {
      var inv = invaders[i];
      if (!inv.alive) {
        // Flash on death
        if (inv.flashTimer > 0) {
          var ix = (inv.baseCol * CELL + CELL / 2) + formationX;
          var iy = (inv.baseRow * CELL + CELL / 2) + formationY;
          ctx.fillStyle = '#ffffff';
          ctx.font = 'bold 14px Courier New';
          ctx.textAlign = 'center';
          ctx.fillText('+' + inv.points, ix, iy);
          ctx.textAlign = 'left';
        }
        continue;
      }
      var x = (inv.baseCol * CELL + CELL / 2) + formationX;
      var y = (inv.baseRow * CELL + CELL / 2) + formationY;

      ctx.save();
      ctx.shadowColor = inv.color;
      ctx.shadowBlur = 8;
      drawInvader(x, y, inv.color, inv.baseRow);
      ctx.restore();
    }
  }

  function drawPlayer() {
    if (invincTimer > 0 && Math.floor(gameTime * 8) % 2 === 0) return;

    var x = player.x;
    var y = player.y;
    var hw = player.w / 2;
    var hh = player.h / 2;

    ctx.save();
    ctx.shadowColor = PLAYER_COLOR;
    ctx.shadowBlur = 14;
    ctx.fillStyle = PLAYER_COLOR;

    // Spaceship shape: triangle top + rect base
    ctx.beginPath();
    ctx.moveTo(x, y - hh - CELL * 0.2);
    ctx.lineTo(x - hw * 0.4, y - hh + CELL * 0.1);
    ctx.lineTo(x + hw * 0.4, y - hh + CELL * 0.1);
    ctx.closePath();
    ctx.fill();

    ctx.fillRect(x - hw, y - hh, player.w, player.h);

    // Notch in base
    ctx.fillStyle = BG_COLOR;
    ctx.fillRect(x - hw * 0.25, y + hh - CELL * 0.15, hw * 0.5, CELL * 0.15);

    ctx.restore();
  }

  function drawBullets() {
    // Player bullet
    if (playerBullet) {
      ctx.save();
      ctx.shadowColor = PROJECTILE_COLOR;
      ctx.shadowBlur = 12;
      ctx.fillStyle = PROJECTILE_COLOR;
      ctx.fillRect(playerBullet.x - 2, playerBullet.y - 8, 4, 16);
      ctx.restore();
    }

    // Enemy bullets
    ctx.fillStyle = '#ff3333';
    for (var i = 0; i < enemyBullets.length; i++) {
      var b = enemyBullets[i];
      ctx.save();
      ctx.shadowColor = '#ff3333';
      ctx.shadowBlur = 8;
      ctx.fillRect(b.x - 2, b.y - 6, 4, 12);
      ctx.restore();
    }
  }

  function drawUI() {
    ctx.font = 'bold 14px Courier New';
    ctx.fillStyle = '#00ff41';

    var scoreText = 'SCORE: ' + score;
    var livesText = 'LIVES: ' + lives;

    ctx.fillText(scoreText, CANVAS_W - 8 - ctx.measureText(scoreText).width, 20);
    ctx.fillText(livesText, 8, 20);

    // High score
    ctx.font = '11px Courier New';
    ctx.fillStyle = '#ffcc00';
    var hiText = 'BEST: ' + highScore;
    ctx.fillText(hiText, CANVAS_W - 8 - ctx.measureText(hiText).width, 34);

    // Wave indicator
    ctx.font = '12px Courier New';
    ctx.fillStyle = '#005511';
    var aliveCount = 0;
    for (var i = 0; i < invaders.length; i++) { if (invaders[i].alive) aliveCount++; }
    var et = 'WAVE ' + wave + '  INVADERS: ' + aliveCount;
    ctx.fillText(et, (CANVAS_W - ctx.measureText(et).width) / 2, 20);
  }

  function draw() {
    ctx.fillStyle = BG_COLOR;
    ctx.fillRect(0, 0, CANVAS_W, CANVAS_H);

    drawGrid();
    drawMysteryShip();
    drawInvaders();
    drawBullets();
    drawPlayer();
    drawUI();

    if (gameState === STATE_GAMEOVER) {
      drawOverlay('GAME OVER', 'Score: ' + score + '  |  Press Enter to restart', '#ef4444');
    } else if (gameState === STATE_WIN) {
      drawOverlay('YOU WIN!', 'Score: ' + score + '  Wave ' + wave + '  |  Press Enter to restart', '#00ff41');
    }
  }

  var lastTime = null;

  function gameLoop(timestamp) {
    if (lastTime === null) lastTime = timestamp;
    var dt = Math.min((timestamp - lastTime) / 1000, 0.05);
    lastTime = timestamp;
    gameTime += dt;

    if (gameState === STATE_PLAYING) {
      if (invincTimer > 0) invincTimer -= dt;
      updatePlayer(dt);
      updateShooting(dt);
      updatePlayerBullet(dt);
      updateFormation(dt);
      updateEnemyShooting(dt);
      updateEnemyBullets(dt);
      updateExplosions(dt);
      updateMysteryShip(dt);
      updateRuleTimers(dt);
      // Update high score
      if (score > highScore) {
        highScore = score;
        localStorage.setItem(HIGH_SCORE_KEY, highScore);
      }
    }

    draw();
    requestAnimationFrame(gameLoop);
  }

  function restartGame() {
    score = 0;
    lives = PLAYER_LIVES;
    wave = 1;
    gameState = STATE_PLAYING;
    shootTimer = 0;
    invincTimer = 0;
    gameTime = 0;
    playerBullet = null;
    enemyBullets = [];
    explosions = [];
    mysteryShip = null;
    mysteryShipTimer = 15 + Math.random() * 15;
    formationStepInterval = 0.8;
    enemyShootInterval = 2.0;
    enemyShootTimer = enemyShootInterval;
    buildGrid();
    initPlayer();
    initInvaders();
  }

  buildGrid();
  initPlayer();
  initInvaders();
  enemyShootTimer = enemyShootInterval;
  requestAnimationFrame(gameLoop);

})();
</script>
</body>
</html>
