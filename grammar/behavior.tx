/*
 * Behavior DSL Grammar
 * Parses .behavior files containing reusable ruleset definitions.
 * Sections inside a ruleset mirror the sections in game.tx.
 */

import game

BehaviorModel:
    rulesets+=RulesetDef
;

RulesetDef:
    'ruleset' name=ID '{'
        (engine=EngineDef)?
        (entities=EntitiesDef)?
        (map=MapDef)?
        (player=PlayerDef)?
        (rules=RulesDef)?
        (variables=VariablesDef)?
        (levels=LevelsDef)?
        (sounds=SoundsDef)?
        (animations=AnimationsDef)?
        (items=ItemsDef)?
        (ui=UIDef)?
    '}'
;
