game "Tetris" {
    canvas: 240x480
    fps: 60
    background: "#0d1117"
}

engine {
    type: grid
    cell_size: 24
    movement: falling
}

entities {
    entity block {
        type: solid
        color: "#4fc3f7"
    }
    entity wall {
        type: solid
        symbol: "#"
        color: "#334455"
    }
}

player {
    name: "Tetris"
    start: (5, 0)
    color: "#4fc3f7"
    speed: 1
    lives: 1
}

rules {
    lose: lives_depleted
}

ui {
    score: top_left
    lives: top_right
}
